        })

    # ── GET /history/export ───────────────────────────────────────────────────
    @app.route("/history/export", methods=["GET"])
    def export_history():
        if not chatbot.history_mgr:
            return jsonify({"success": False, "error": "History manager not initialized"}), 503
        token, session_info = _get_token_user(request)
