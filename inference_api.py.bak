# =============================================================================
# METRICS TRACKER
# =============================================================================

class MetricsTracker:
    def __init__(self, metrics_file: str):
        self.metrics_file = Path(metrics_file)
        self._lock = threading.Lock()
        self.metrics = self._load()

    def _load(self) -> Dict:
        if self.metrics_file.exists():
            try:
                with open(self.metrics_file, "r", encoding="utf-8") as f:
                    return json.load(f)
            except Exception:
                pass
        return {
            "rag_performance": [], "rl_rewards": [], "query_times": [],
            "user_ratings": [], "intent_distribution": {}, "topic_distribution": {},
            "character_distribution": {}, "retrieval_scores": [], "training_metrics": []
        }

    def _save(self):
        with self._lock:
            with open(self.metrics_file, "w", encoding="utf-8") as f:
                json.dump(self.metrics, f, indent=2)

    def log_training_metric(self, step, loss, epoch):
        self.metrics["training_metrics"].append({
            "step": int(step), "loss": float(loss), "epoch": float(epoch),
            "timestamp": datetime.utcnow().isoformat()
        })
        self._save()

    def log_rag_performance(self, query, retrieval_time, similarity_scores, num_docs):
        avg = float(np.mean(similarity_scores)) if similarity_scores else 0.0
        self.metrics["rag_performance"].append({
            "timestamp": datetime.utcnow().isoformat(), "query": query,
            "retrieval_time": float(retrieval_time), "avg_similarity": avg,
            "max_similarity": float(max(similarity_scores)) if similarity_scores else 0.0,
            "num_docs": int(num_docs)
        })
        self.metrics["retrieval_scores"].extend([float(s) for s in similarity_scores])
        self._save()

    def log_rl_reward(self, user_id, character, topic, reward):
        self.metrics["rl_rewards"].append({
            "timestamp": datetime.utcnow().isoformat(),
            "user_id": user_id, "character": character,
            "topic": topic, "reward": float(reward)
        })
        self._save()

    def log_query_time(self, query, character, total_time):
        self.metrics["query_times"].append({
            "timestamp": datetime.utcnow().isoformat(),
            "query": query, "character": character, "time": float(total_time)
        })
        self._save()

    def log_user_rating(self, user_id, character, rating, topic):
        self.metrics["user_ratings"].append({
            "timestamp": datetime.utcnow().isoformat(),
            "user_id": user_id, "character": character,
            "rating": float(rating), "topic": topic
        })
        self._save()

    def log_intent(self, intent):
        self.metrics["intent_distribution"][intent] = \
            self.metrics["intent_distribution"].get(intent, 0) + 1
        self._save()

    def log_topic(self, topic):
        self.metrics["topic_distribution"][topic] = \
            self.metrics["topic_distribution"].get(topic, 0) + 1
        self._save()

    def log_character(self, character):
        self.metrics["character_distribution"][character] = \
            self.metrics["character_distribution"].get(character, 0) + 1
        self._save()

