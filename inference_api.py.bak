    def __init__(self):
        self.session_scores = defaultdict(lambda: {"xp": 0, "correct": 0, "total": 0, "completed": []})
        print("VR Quiz Engine initialized")

    def generate_quiz(self, character_id: str, quiz_type: str = "multiple_choice",
                      difficulty: str = "medium", session_id: str = "default") -> Dict:
        """Generate a quiz question appropriate for the character and difficulty."""
        import random
        result = {"character_id": character_id, "quiz_type": quiz_type,
                  "difficulty": difficulty, "session_id": session_id}

        if quiz_type == "multiple_choice":
            pool = self.QUIZ_TEMPLATES["multiple_choice"].get(character_id, [])
            if not pool:
                pool = []
                for char_pool in self.QUIZ_TEMPLATES["multiple_choice"].values():
                    pool.extend(char_pool)
            q = random.choice(pool) if pool else None
            if q:
                result.update({"question": q["q"], "options": q["options"],
                                "answer": q["answer"], "explanation": q["explanation"],
                                "xp_reward": {"easy": 10, "medium": 25, "hard": 50}.get(difficulty, 25)})

        elif quiz_type == "true_false":
            q = random.choice(self.QUIZ_TEMPLATES["true_false"])
            result.update({"question": q["q"], "answer": q["answer"],
                           "explanation": q["explanation"], "xp_reward": 15})

        elif quiz_type == "fill_blank":
            q = random.choice(self.QUIZ_TEMPLATES["fill_blank"])
            result.update({"question": q["q"], "hint": q["hint"],
                           "answer": q["answer"], "xp_reward": 30})

        elif quiz_type == "vr_challenge":
            available = [c for c in self.QUIZ_TEMPLATES["vr_challenges"]
                         if c["id"] not in self.session_scores[session_id]["completed"]]
            if not available:
                available = self.QUIZ_TEMPLATES["vr_challenges"]
            challenge = random.choice(available)
            result.update({"challenge_id": challenge["id"], "title": challenge["title"],
                           "description": challenge["description"], "choices": challenge["choices"],
                           "xp_reward": challenge["xp"]})

        return result

    def submit_answer(self, session_id: str, quiz_type: str, user_answer,
                      correct_answer, xp_reward: int = 25, challenge_id: str = None) -> Dict:
        """Process answer submission and update XP."""
        score = self.session_scores[session_id]
        score["total"] += 1

        if quiz_type == "multiple_choice":
            is_correct = str(user_answer).upper().strip() == str(correct_answer).upper().strip()
        elif quiz_type == "true_false":
            is_correct = str(user_answer).lower() in ["true", "yes", "1"] == correct_answer
        elif quiz_type == "fill_blank":
            is_correct = user_answer.lower().strip() == correct_answer.lower().strip()
        elif quiz_type == "vr_challenge":
            is_correct = bool(user_answer)
            if challenge_id:
                score["completed"].append(challenge_id)
        else:
            is_correct = False

        if is_correct:
            score["correct"] += 1
            score["xp"] += xp_reward

        return {
            "correct": is_correct,
            "xp_earned": xp_reward if is_correct else 0,
            "total_xp": score["xp"],
            "accuracy": round(score["correct"] / score["total"] * 100, 1) if score["total"] > 0 else 0,
            "session_stats": dict(score)
        }

    def get_leaderboard(self) -> List[Dict]:
        """Return ranked leaderboard of all sessions."""
        lb = [{"session_id": sid, "xp": s["xp"],
                "accuracy": round(s["correct"] / s["total"] * 100, 1) if s["total"] > 0 else 0,
                "total_answered": s["total"]}
              for sid, s in self.session_scores.items()]
        return sorted(lb, key=lambda x: x["xp"], reverse=True)


# =============================================================================
# PREDICTIVE TOPIC ENGINE
# Predicts next topics the user will be curious about and preloads content
# =============================================================================

class PredictiveTopicEngine:
    # Topic transition graph — what topics naturally follow others
    TOPIC_GRAPH = {
        "king":      ["temple", "kingdom", "buddhism", "colonial"],
        "temple":    ["festival", "buddhism", "king", "colonial"],
        "festival":  ["temple", "buddhism", "kingdom"],
        "kingdom":   ["king", "colonial", "trade", "fort"],
        "buddhism":  ["temple", "festival", "king"],
        "fort":      ["trade", "colonial", "dutch"],
        "trade":     ["colonial", "fort", "dutch"],
        "colonial":  ["fort", "trade", "kingdom"],
        "general":   ["king", "temple", "festival", "fort"]
    }

    TOPIC_CONTENT_MAP = {
        "temple":   ["What is the Temple of the Tooth?", "What are the daily rituals at the temple?"],
        "festival": ["What is the Esala Perahera?", "How long does the Perahera last?"],
        "fort":     ["Tell me about Galle Fort", "How many bastions does Galle Fort have?"],
        "trade":    ["What were the main exports during Dutch rule?", "What was cinnamon used for?"],
        "colonial": ["What was the Dutch East India Company's role in Ceylon?", "When did the British take over?"],
        "kingdom":  ["How did the Kingdom of Kandy maintain independence?", "What is the significance of Kandy?"],
        "buddhism": ["When did Buddhism arrive in Sri Lanka?", "What Buddhist relics are in Kandy?"],
        "king":     ["Who was Sri Vijaya Rajasinha?", "What was King Rajasinha's greatest achievement?"]
    }

    def __init__(self):
        self.preloaded_cache = {}
        self.user_sequences = defaultdict(list)
        print("Predictive Topic Engine initialized")

    def predict_next_topics(self, session_id: str, current_topic: str,
                            character_id: str, history: List[str], top_n: int = 3) -> List[Dict]:
        """Predict the most likely next topics based on current topic and history."""
        candidates = self.TOPIC_GRAPH.get(current_topic, self.TOPIC_GRAPH["general"])
        # Boost topics not yet visited
        visited = set(history[-5:]) if history else set()
        scored = []
        for topic in candidates:
            score = 1.0
            if topic in visited:
                score *= 0.3  # penalize already-visited
            if topic in CHARACTERS.get(character_id, {}).get("expertise", []):
                score *= 1.5  # boost character-relevant topics
            scored.append((topic, score))
        scored.sort(key=lambda x: x[1], reverse=True)
        predictions = []
        for topic, score in scored[:top_n]:
            questions = self.TOPIC_CONTENT_MAP.get(topic, [])
            predictions.append({
                "predicted_topic": topic,
                "confidence": round(min(score, 1.0), 2),
                "suggested_questions": questions[:2],
                "preloaded": topic in self.preloaded_cache
            })
        return predictions

    def record_topic_visit(self, session_id: str, topic: str):
        self.user_sequences[session_id].append(topic)
        if len(self.user_sequences[session_id]) > 20:
            self.user_sequences[session_id] = self.user_sequences[session_id][-20:]

    def preload_topic(self, topic: str, content: str):
        self.preloaded_cache[topic] = {"content": content, "cached_at": datetime.now().isoformat()}

    def get_preloaded(self, topic: str) -> Optional[str]:
        cached = self.preloaded_cache.get(topic)
        return cached["content"] if cached else None


# =============================================================================
# USER EXPERTISE ADAPTER
# Adapts storytelling style by age/expertise: child, student, researcher, tourist
# =============================================================================

class UserExpertiseAdapter:
    PROFILES = {
        "child": {
            "description": "Child (age 6-12)",
            "vocabulary": "simple",
            "sentence_length": "short",
            "use_analogies": True,
            "use_emoji": True,
            "detail_level": "basic",
            "system_suffix": (
                "Speak very simply, like explaining to a curious 8-year-old. "
                "Use short sentences. Avoid complex words. "
                "Use fun comparisons like 'as big as a school bus'. Add enthusiasm!"
            )
        },
        "student": {
            "description": "Student (age 13-22)",
            "vocabulary": "moderate",
            "sentence_length": "medium",
            "use_analogies": True,
            "use_emoji": False,
            "detail_level": "moderate",
            "system_suffix": (
                "Speak clearly and educationally. Use some historical terminology "
                "but explain it when you do. Connect events to causes and effects. "
                "Be engaging and informative."
            )
        },
        "researcher": {
            "description": "Researcher / Academic",
            "vocabulary": "advanced",
            "sentence_length": "long",
            "use_analogies": False,
            "use_emoji": False,
            "detail_level": "deep",
            "system_suffix": (
                "Speak with academic precision. Use correct historical terminology. "
                "Cite specific dates, names, and sources where possible. "
                "Acknowledge historical debates and uncertainties. Be thorough."
            )
        },
        "tourist": {
            "description": "Tourist / Casual Visitor",
            "vocabulary": "accessible",
            "sentence_length": "medium",
            "use_analogies": True,
            "use_emoji": False,
            "detail_level": "engaging",
            "system_suffix": (
                "Be warm, enthusiastic, and descriptive. Paint a vivid picture. "
                "Highlight what the visitor will SEE, HEAR, and FEEL. "
                "Include practical tips and interesting anecdotes. Be a great tour guide!"
            )
        }
    }

    def __init__(self):
        self.user_levels = {}
        print("User Expertise Adapter initialized")

    def set_user_level(self, session_id: str, level: str):
        if level in self.PROFILES:
            self.user_levels[session_id] = level
            return True
        return False

    def get_user_level(self, session_id: str) -> str:
        return self.user_levels.get(session_id, "tourist")

    def adapt_system_prompt(self, base_prompt: str, session_id: str) -> str:
        level = self.get_user_level(session_id)
        profile = self.PROFILES.get(level, self.PROFILES["tourist"])
        return base_prompt + " " + profile["system_suffix"]

    def get_all_profiles(self) -> Dict:
        return {k: {"description": v["description"], "detail_level": v["detail_level"]}
                for k, v in self.PROFILES.items()}


# =============================================================================
# CULTURAL SENSITIVITY ENGINE
# Detects sensitive topics and tailors language/tone for respectful storytelling
# =============================================================================

class CulturalSensitivityEngine:
    SENSITIVE_TOPICS = {
        "colonial_violence": {
            "keywords": ["massacre", "killed", "torture", "slavery", "forced", "oppression", "genocide"],
            "tone": "respectful_acknowledgment",
            "guidance": (
                "Acknowledge the historical hardship with empathy and respect. "
                "Do not glorify or minimize. Present from multiple perspectives. "
                "Use measured, dignified language."
            )
        },
        "religious_controversy": {
            "keywords": ["convert", "destroy temple", "religious conflict", "persecution", "heresy"],
            "tone": "neutral_respectful",
            "guidance": (
                "Treat all religious perspectives with equal respect. "
                "Present historical facts without judgment. "
                "Acknowledge the spiritual significance to believers."
            )
        },
        "ethnic_tensions": {
            "keywords": ["sinhalese", "tamil", "conflict", "war", "discrimination", "civil war"],
            "tone": "balanced_sensitive",
            "guidance": (
                "Present a balanced view acknowledging all communities. "
                "Focus on shared history and cultural contributions. "
                "Avoid language that assigns collective blame."
            )
        },
        "colonial_pride": {
            "keywords": ["civilized", "primitive", "backward", "inferior", "savage"],
            "tone": "corrective_respectful",
            "guidance": (
                "Gently correct colonial-era biases. "
                "Highlight the sophistication of pre-colonial Sri Lankan civilization. "
                "Use contemporary, respectful terminology."
            )
        }
    }

    def __init__(self):
        print("Cultural Sensitivity Engine initialized")

    def analyze(self, query: str) -> Dict:
        """Detect sensitive topics in a query and return guidance."""
        q = query.lower()
        detected = []
        for topic_key, topic_data in self.SENSITIVE_TOPICS.items():
            if any(kw in q for kw in topic_data["keywords"]):
                detected.append({
                    "sensitivity_type": topic_key,
                    "tone": topic_data["tone"],
                    "guidance": topic_data["guidance"]
                })
        return {
            "is_sensitive": len(detected) > 0,
            "detected_sensitivities": detected,
            "combined_guidance": " ".join(d["guidance"] for d in detected) if detected else ""
        }

    def apply_to_prompt(self, system_prompt: str, query: str) -> str:
        """Augment system prompt with cultural sensitivity guidance if needed."""
        analysis = self.analyze(query)
        if analysis["is_sensitive"] and analysis["combined_guidance"]:
            return system_prompt + " CULTURAL SENSITIVITY NOTE: " + analysis["combined_guidance"]
        return system_prompt


