                    char_label = gr.Markdown("**King Sri Vijaya Rajasinha** — Last King of Kandy")
                    char_radio.change(set_character, [char_radio], [char_label])
                    gr.Markdown("""
                    ---
                    **King** — Tooth Relic, Buddhism, Kandy

                    **Nilame** — Temple, Perahera, Rituals

                    **Dutch Captain** — Galle Fort, VOC, Trade

                    **Historian** — Full History, Culture
                    """)
            gr.Markdown("### Live Enrichments")
