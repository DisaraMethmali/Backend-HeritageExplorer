    # ── Global error handlers ──────────────────────────────────────────────────
    @app.errorhandler(404)
    def not_found(e):
        return jsonify({
            "error": "Endpoint not found",
            "hint":  "Visit http://localhost:5000/ for the full endpoint list"
        }), 404

    @app.errorhandler(405)
    def method_not_allowed(e):
        return jsonify({
            "error": "Method Not Allowed",
            "hint": (
                "/chat, /chat/all, /chat/multi, /generate, /generate/all, "
                "/api/feedback all require POST with Content-Type: application/json"
            ),
            "example": (
                'curl -X POST http://localhost:5000/chat/all '
                '-H "Content-Type: application/json" '
                '-d \'{"query": "What is the Esala Perahera?"}\'' 
            )
        }), 405

    # =========================================================================
    # /ask  ENDPOINTS  — question + reply from each character, cleanly paired
    # =========================================================================

    # ── /ask  — ask ALL 4 characters, get question+reply from each ────────────
    @app.route("/ask", methods=["GET", "POST"])
    def ask_all():
        """
        The main "ask everyone" endpoint.
        POST one question → receive question + reply from every character.
        Each reply includes character_id so the caller always knows who said what.
        """
        if request.method == "GET":
            return jsonify({
                "info": (
                    "POST a question and receive a reply from EVERY character. "
                    "Each reply includes character_id, character_name, title, "
                    "question, and answer."
                ),
                "required_fields": {"question": "string"},
                "optional_fields": {"session_id": "string (default: default)"},
                "valid_character_ids": list(CHARACTERS.keys()),
                "characters": {
                    cid: {"name": c["name"], "title": c["title"]}
                    for cid, c in CHARACTERS.items()
                },
                "example_request": {
                    "question": "What is the Sacred Tooth Relic?",
                    "session_id": "user_1"
                },
                "example_response": {
                    "success": True,
                    "question": "What is the Sacred Tooth Relic?",
                    "total_replies": 4,
                    "replies": [
                        {
                            "character_id":   "king",
                            "character_name": "King Sri Vijaya Rajasinha",
                            "title":          "Last King of Kandy (1739-1747)",
                            "question":       "What is the Sacred Tooth Relic?",
                            "answer":         "The Sacred Tooth Relic is...",
                            "confidence":     0.97,
                            "intent":         "description",
                            "topic":          "temple"
                        },
                        {"character_id": "nilame", "answer": "..."},
                        {"character_id": "dutch",  "answer": "..."},
                        {"character_id": "citizen","answer": "..."}
                    ]
                },
                "curl": (
                    'curl -X POST http://localhost:5000/ask '
                    '-H "Content-Type: application/json" '
                    '-d \'{"question": "What is the Esala Perahera?", "session_id": "user_1"}\''
                )
            }), 200

        try:
            data       = request.get_json(force=True, silent=True) or {}
            # Accept both "question" and "query" keys
            question   = data.get("question") or data.get("query", "")
            session_id = data.get("session_id", "default")

            if not question:
                return jsonify({
                    "error": "'question' field is required",
                    "example": {"question": "Tell me about Galle Fort",
                                "session_id": "user_1"}
                }), 400

            # Ask every character
            replies = _ask_characters(
                chatbot, question, list(CHARACTERS.keys()), session_id
            )

            return jsonify({
                "success":       True,
                "question":      question,
                "session_id":    session_id,
                "total_replies": len(replies),
                "replies":       replies,
                "timestamp":     datetime.now().isoformat()
            })

        except Exception as e:
            return jsonify({"success": False, "error": str(e)}), 500

    # ── /ask/<character_id>  — ask ONE specific character ─────────────────────
    @app.route("/ask/<character_id>", methods=["GET", "POST"])
    def ask_character(character_id):
        """
        Ask a specific character by ID in the URL.
        Returns the question and that character's reply together.
        character_id must be one of: king, nilame, dutch, citizen
        """
        if character_id not in CHARACTERS:
            return jsonify({
                "error": f"Unknown character_id '{character_id}'",
                "valid_character_ids": list(CHARACTERS.keys()),
                "usage": {
                    "king":    "http://localhost:5000/ask/king",
                    "nilame":  "http://localhost:5000/ask/nilame",
                    "dutch":   "http://localhost:5000/ask/dutch",
                    "citizen": "http://localhost:5000/ask/citizen"
                }
            }), 404

        char = CHARACTERS[character_id]

        if request.method == "GET":
            return jsonify({
                "info": f"POST a question to get a reply from {char['name']}.",
                "character_id":   character_id,
                "character_name": char["name"],
                "title":          char["title"],
                "expertise":      char["expertise"],
                "required_fields": {"question": "string"},
                "optional_fields": {"session_id": "string"},
                "example_request": {
                    "question":  "Tell me about yourself",
                    "session_id": "user_1"
                },
                "curl": (
                    f'curl -X POST http://localhost:5000/ask/{character_id} '
                    f'-H "Content-Type: application/json" '
                    f'-d \'{{"question": "Hello, who are you?", "session_id": "user_1"}}\''
                )
            }), 200

        try:
            data       = request.get_json(force=True, silent=True) or {}
            question   = data.get("question") or data.get("query", "")
            session_id = data.get("session_id", "default")

            if not question:
                return jsonify({
                    "error": "'question' field is required",
                    "example": {"question": "Tell me about the Tooth Relic"}
                }), 400

            resp = chatbot.generate_answer(question, character_id, session_id)

            return jsonify({
                "success":        True,
                "character_id":   character_id,
                "character_name": char["name"],
                "title":          char["title"],
                "question":       question,
                "answer":         resp.get("answer", ""),
                "confidence":     resp.get("confidence"),
                "intent":         resp.get("intent"),
                "topic":          resp.get("topic"),
                "session_id":     session_id,
                "retrieval_time": resp.get("retrieval_time"),
                "total_time":     resp.get("total_time"),
                "timestamp":      datetime.now().isoformat()
            })

        except Exception as e:
            return jsonify({"success": False, "error": str(e)}), 500

    # ── /ask/compare  — ask 2+ characters and show their answers side-by-side ──
    @app.route("/ask/compare", methods=["GET", "POST"])
    def ask_compare():
        """
        Ask the same question to 2 or more characters and return
        their answers formatted for easy side-by-side comparison.
        """
        if request.method == "GET":
            return jsonify({
                "info": (
                    "Ask the same question to multiple characters and compare "
                    "their different perspectives."
                ),
                "required_fields": {
                    "question":      "string",
                    "character_ids": "list of 2-4 character IDs"
                },
                "optional_fields": {"session_id": "string"},
                "valid_character_ids": list(CHARACTERS.keys()),
                "example_request": {
                    "question":      "What do you think about the Kandyan Kingdom?",
                    "character_ids": ["king", "dutch"],
                    "session_id":    "user_1"
                },
                "curl": (
                    'curl -X POST http://localhost:5000/ask/compare '
                    '-H "Content-Type: application/json" '
                    '-d \'{"question": "Tell me about Kandy", '
                    '"character_ids": ["king", "citizen"]}\''
                )
            }), 200

        try:
            data          = request.get_json(force=True, silent=True) or {}
            question      = data.get("question") or data.get("query", "")
            character_ids = data.get("character_ids", list(CHARACTERS.keys()))
            session_id    = data.get("session_id", "default")

            if not question:
                return jsonify({"error": "'question' field is required"}), 400
            if not isinstance(character_ids, list) or len(character_ids) < 1:
                return jsonify({
                    "error": "'character_ids' must be a list with at least 1 ID",
                    "valid_character_ids": list(CHARACTERS.keys())
                }), 400

            # Expand "all" shorthand
            if "all" in character_ids:
                character_ids = list(CHARACTERS.keys())

            # Validate each ID
            invalid = [c for c in character_ids if c not in CHARACTERS]
            if invalid:
                return jsonify({
                    "error": f"Unknown character_id(s): {invalid}",
                    "valid_character_ids": list(CHARACTERS.keys())
                }), 400

            replies = _ask_characters(chatbot, question, character_ids, session_id)

            # Build a comparison dict keyed by character_id for easy lookup
            comparison = {}
            for r in replies:
                cid = r["character_id"]
                comparison[cid] = {
                    "character_name": r["character_name"],
                    "title":          r["title"],
                    "answer":         r["answer"],
                    "confidence":     r.get("confidence"),
                    "topic":          r.get("topic"),
                    "intent":         r.get("intent"),
                }

            return jsonify({
                "success":          True,
                "question":         question,
                "session_id":       session_id,
                "characters_asked": character_ids,
                "comparison":       comparison,       # keyed by character_id
                "replies":          replies,           # also as ordered list
                "timestamp":        datetime.now().isoformat()
            })

        except Exception as e:
            return jsonify({"success": False, "error": str(e)}), 500


