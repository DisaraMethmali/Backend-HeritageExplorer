                crit_box    = gr.Markdown(label="Critical Thinking Challenge")

            msg.submit(chat_fn, [msg, chatbot_ui, sid, expertise_dd],
                       [chatbot_ui, msg, folklore_box, chain_box, enrich_box, crit_box])
            send_btn.click(chat_fn, [msg, chatbot_ui, sid, expertise_dd],
                           [chatbot_ui, msg, folklore_box, chain_box, enrich_box, crit_box])

        # ── Tab 2: VR Quiz ────────────────────────────────────────────────────
