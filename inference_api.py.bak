    # ── /predict/topics — Predictive topic suggestions ────────────────────────
    @app.route("/predict/topics", methods=["GET", "POST"])
    def predict_topics():
        if request.method == "GET":
            return jsonify({
                "info": "Predict the next topics the user is likely to ask about.",
                "fields": {"session_id": "string", "current_topic": "string",
                           "character_id": "string", "top_n": "int (default 3)"}
            }), 200
        try:
            data = request.get_json(force=True, silent=True) or {}
            sid = data.get("session_id", "default")
            history = chatbot.temporal_memory.get_user_memory(sid).get("narrative_thread", [])
            history_topics = [h.get("topic", "") for h in history[-5:]]
            predictions = chatbot.predictor.predict_next_topics(
                session_id=sid,
                current_topic=data.get("current_topic", "general"),
                character_id=data.get("character_id", "citizen"),
                history=history_topics,
                top_n=int(data.get("top_n", 3))
            )
            return jsonify({"success": True, "predictions": predictions,
                            "timestamp": datetime.now().isoformat()})
        except Exception as e:
            return jsonify({"success": False, "error": str(e)}), 500

