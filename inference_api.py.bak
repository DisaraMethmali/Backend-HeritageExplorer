    # ── GET /auth/users ───────────────────────────────────────────────────────
    @app.route("/auth/users", methods=["GET"])
    def auth_list_users():
        if not chatbot.auth:
            return jsonify({"success": False, "error": "Auth not initialized"}), 503
        return jsonify({
            "success": True,
            "users":   chatbot.auth.list_users(),
            "stats":   chatbot.auth.get_stats(),
            "timestamp": datetime.now().isoformat()
        })

    # ── DELETE /auth/users/<username> ─────────────────────────────────────────
    @app.route("/auth/users/<username>", methods=["DELETE"])
    def auth_delete_user(username):
        if not chatbot.auth:
            return jsonify({"success": False, "error": "Auth not initialized"}), 503
        token, session_info = _get_token_user(request)
        if not session_info:
            return jsonify({"success": False, "error": "Unauthorized"}), 401
        # Only allow self-deletion (add admin role check here if needed)
        if session_info["username"] != username.lower():
            return jsonify({"success": False, "error": "Can only delete your own account"}), 403
        result = chatbot.auth.delete_user(username.lower())
        return jsonify(result)

    # =========================================================================
    # CHAT HISTORY API ENDPOINTS
    # =========================================================================

    # ── GET /history ──────────────────────────────────────────────────────────
    @app.route("/history", methods=["GET", "POST"])
    def get_chat_history():
        if not chatbot.history_mgr:
            return jsonify({"success": False, "error": "History manager not initialized"}), 503
        
        # Support both GET and POST — both require auth token
        token, session_info = _get_token_user(request)
        if not session_info:
            return jsonify({"success": False, "error": "Unauthorized — login first"}), 401

        # Read params from query string (GET) or JSON body (POST)
        if request.method == "POST":
            data = request.get_json(force=True, silent=True) or {}
        else:
            data = {}

        params = {**data, **dict(request.args)}  # query string overrides body

        try:
            result = chatbot.history_mgr.get_history(
                username     = session_info["username"],
                session_id   = params.get("session_id"),
                character_id = params.get("character_id"),
                topic        = params.get("topic"),
                search       = params.get("search"),
                limit        = int(params.get("limit", 50)),
                offset       = int(params.get("offset", 0)),
                date_from    = params.get("date_from"),
                date_to      = params.get("date_to")
            )
            return jsonify({
                "success":   True,
                "username":  session_info["username"],
                **result,
                "timestamp": datetime.now().isoformat()
            })
        except Exception as e:
            return jsonify({"success": False, "error": str(e)}), 500

    # ── GET /history/sessions ─────────────────────────────────────────────────
    @app.route("/history/sessions", methods=["GET"])
    def get_history_sessions():
        if not chatbot.history_mgr:
            return jsonify({"success": False, "error": "History manager not initialized"}), 503
        token, session_info = _get_token_user(request)
        if not session_info:
            return jsonify({"success": False, "error": "Unauthorized"}), 401
        sessions = chatbot.history_mgr.get_session_list(session_info["username"])
        return jsonify({
            "success":  True,
            "username": session_info["username"],
            "sessions": sessions,
            "total_sessions": len(sessions),
            "timestamp": datetime.now().isoformat()
        })

    # ── GET /history/stats ────────────────────────────────────────────────────
    @app.route("/history/stats", methods=["GET"])
    def get_history_stats():
        if not chatbot.history_mgr:
