            gr.Button("Start Fine-tuning", variant="primary").click(run_finetune, outputs=tune_out)
            gr.Markdown("---\n### Step 2 — Upload to PUBLIC HuggingFace repo\nGet write token: https://huggingface.co/settings/tokens")
            hf_tok  = gr.Textbox(label="HF Write Token", placeholder="hf_xxxx", type="password")
