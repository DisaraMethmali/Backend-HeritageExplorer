            "legend": (
                "Local tradition holds that the spirits of Dutch soldiers still patrol the ramparts "
                "of Galle Fort at night. Fishermen refuse to sail past certain points after dark, "
                "believing the cannon-fire ghosts warn of storms and protect honest sailors."
            ),
            "historical_fact": (
                "Galle Fort was built by the Dutch between 1663-1669. Many soldiers died defending it. "
                "The fort is remarkably well-preserved and is a UNESCO World Heritage Site."
            ),
            "keywords": ["ghost", "spirit", "galle fort legend", "haunted", "dutch ghost"]
        },
        "perahera_elephant": {
            "title": "The Sacred Elephant of the Perahera",
            "legend": (
                "It is said that the lead elephant of the Esala Perahera is chosen by divine will — "
                "that the elephant must willingly accept the golden howdah (carriage) bearing the "
                "sacred reliquary. If an elephant refuses, it is seen as a divine omen."
            ),
            "historical_fact": (
                "The Esala Perahera has been held annually for over 2,000 years. "
                "The lead elephant carries an ornate reliquary casket (not the actual relic itself). "
                "The selection of the Maligawa Tusker is a serious ceremonial process."
            ),
            "keywords": ["perahera elephant", "tusker", "maligawa elephant", "elephant ceremony"]
        }
    }

    def __init__(self):
        print("Legend and Folklore Engine initialized")

    def find_relevant_legend(self, query: str) -> Optional[Dict]:
        q = query.lower()
        for key, legend in self.LEGENDS.items():
            if any(kw in q for kw in legend["keywords"]):
                return legend
        return None

    def enrich_response(self, response: str, query: str) -> Dict:
        legend = self.find_relevant_legend(query)
        if legend:
            return {
                "enriched": True,
                "legend_title": legend["title"],
                "legend": legend["legend"],
                "historical_fact": legend["historical_fact"],
                "base_response": response
            }
        return {"enriched": False, "base_response": response}


# =============================================================================
# CAUSAL CHAIN REASONING ENGINE
# Explains cause-and-effect chains between historical events
# =============================================================================

class CausalChainEngine:
    CHAINS = {
        "kandyan_independence": {
            "title": "How Kandy Remained Independent",
            "chain": [
                {"event": "Geographic Isolation", "year": "Before 1600s",
                 "cause": "Kandy was located in steep central highlands",
                 "effect": "Portuguese and Dutch armies could not effectively march armies uphill through dense jungle"},
                {"event": "Portuguese Invasion Attempts", "year": "1500s-1600s",
                 "cause": "Portuguese controlled coastal Ceylon and wanted inland trade routes",
                 "effect": "Multiple invasion attempts failed due to terrain; Kandyan guerrilla tactics prevailed"},
                {"event": "Dutch Alliance", "year": "1638",
                 "cause": "Kandy allied with Dutch against Portuguese",
                 "effect": "Dutch expelled Portuguese from coasts, but Kandy maintained sovereignty over interior"},
                {"event": "Kingdom Endured", "year": "Until 1815",
                 "cause": "Consistent policy of not surrendering — every king defended independence",
                 "effect": "Kandy survived 300+ years of colonial pressure, the last independent kingdom in Sri Lanka"}
            ]
        },
        "dutch_cinnamon_trade": {
            "title": "How Cinnamon Built Dutch Ceylon",
            "chain": [
                {"event": "Cinnamon Discovery", "year": "1500s",
                 "cause": "Europeans discovered Ceylon cinnamon was far superior to Asian alternatives",
                 "effect": "Ceylon became strategically vital to European spice trade"},
                {"event": "VOC Monopoly", "year": "1658",
                 "cause": "Dutch expelled Portuguese and established VOC control over coasts",
                 "effect": "Complete monopoly on cinnamon export; prices controlled globally"},
                {"event": "Peelers' System", "year": "1658-1796",
                 "cause": "VOC needed reliable cinnamon peeling",
                 "effect": "Salagama caste was compelled to peel cinnamon under Dutch rule, reshaping social structures"},
                {"event": "British Takeover", "year": "1796",
                 "cause": "Napoleonic Wars weakened the Netherlands; Britain occupied Dutch colonies",
                 "effect": "British inherited the cinnamon monopoly and eventually opened free trade"}
            ]
        },
        "tooth_relic_power": {
            "title": "Why the Tooth Relic Determined Kingship",
            "chain": [
                {"event": "Relic Arrives in Lanka", "year": "4th century CE",
                 "cause": "Buddhist belief that the Relic conferred divine right to rule",
                 "effect": "Whoever possessed the Relic was considered the legitimate Buddhist king"},
                {"event": "Relic Becomes Political", "year": "Medieval period",
                 "cause": "Kings used the Relic to legitimize their rule to Buddhist subjects",
                 "effect": "Every conquering king made securing the Relic their first priority"},
                {"event": "Kandy Becomes Custodian", "year": "1592",
                 "cause": "Kandyan kings successfully defended the Relic from Portuguese",
                 "effect": "Kandy's legitimacy as the Buddhist capital of Lanka was cemented"},
                {"event": "British Respect the Relic", "year": "1815",
                 "cause": "British signed Kandyan Convention promising to protect Buddhist institutions",
                 "effect": "Temple of the Tooth was preserved under British rule; tradition continues today"}
            ]
        }
    }

    KEYWORDS = {
        "kandyan_independence": ["kandy independence", "why kandy", "how kandy survived", "kandy resist"],
        "dutch_cinnamon_trade": ["cinnamon trade", "dutch trade", "spice trade", "voc trade"],
        "tooth_relic_power": ["why tooth relic", "relic power", "relic king", "relic legitimacy"]
    }

    def __init__(self):
        print("Causal Chain Engine initialized")

    def find_chain(self, query: str) -> Optional[Dict]:
        q = query.lower()
        for chain_key, keywords in self.KEYWORDS.items():
            if any(kw in q for kw in keywords):
                return self.CHAINS.get(chain_key)
        # Fuzzy: check for "why", "how", "cause", "lead to"
        if any(w in q for w in ["why did", "how did", "what caused", "what led", "chain of"]):
            # Return the most topically relevant chain
            for chain_key, keywords in self.KEYWORDS.items():
                topic_words = [kw.split()[0] for kw in keywords]
                if any(tw in q for tw in topic_words):
                    return self.CHAINS.get(chain_key)
        return None

    def format_chain(self, chain: Dict) -> str:
        lines = [f"HISTORICAL CHAIN: {chain['title']}", ""]
        for i, step in enumerate(chain["chain"], 1):
            lines.append(f"Step {i}: {step['event']} ({step['year']})")
            lines.append(f"  CAUSE:  {step['cause']}")
            lines.append(f"  EFFECT: {step['effect']}")
            lines.append("")
        return "\n".join(lines)



