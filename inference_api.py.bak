    # =========================================================================
    # USER AUTHENTICATION API ENDPOINTS
    # =========================================================================

    def _get_token_user(req):
        """Extract and verify Bearer token from Authorization header."""
        auth_header = req.headers.get("Authorization", "")
        if auth_header.startswith("Bearer "):
            token = auth_header[7:].strip()
        else:
            token = req.args.get("token", "") or (req.get_json(force=True, silent=True) or {}).get("token", "")
        if not token:
            return None, None
        session_info = chatbot.auth.verify_token(token) if chatbot.auth else None
        return token, session_info

    # ── POST /auth/register ───────────────────────────────────────────────────
    @app.route("/auth/register", methods=["GET", "POST"])
    def auth_register():
        if request.method == "GET":
            return jsonify({
                "info": "Register a new user account.",
                "required_fields": {
                    "username": "string (3+ chars, letters/numbers/_ only)",
                    "email":    "valid email address",
                    "password": "string (6+ chars)"
                },
                "optional_fields": {
                    "full_name":       "string",
                    "age_group":       "child|teen|adult|senior (default: adult)",
                    "expertise_level": "child|student|researcher|tourist (default: tourist)"
                },
                "example": {
                    "username":       "john_doe",
                    "email":          "john@example.com",
                    "password":       "secure123",
                    "full_name":      "John Doe",
                    "expertise_level":"student"
                }
            }), 200
        if not chatbot.auth:
            return jsonify({"success": False, "error": "Auth not initialized"}), 503
        try:
            data = request.get_json(force=True, silent=True) or {}
            result = chatbot.auth.register(
                username       = data.get("username", ""),
                email          = data.get("email", ""),
                password       = data.get("password", ""),
                full_name      = data.get("full_name", ""),
                age_group      = data.get("age_group", "adult"),
                expertise_level= data.get("expertise_level", "tourist")
            )
            status = 201 if result["success"] else 400
            return jsonify(result), status
        except Exception as e:
            return jsonify({"success": False, "error": str(e)}), 500

    # ── POST /auth/login ──────────────────────────────────────────────────────
    @app.route("/auth/login", methods=["GET", "POST"])
    def auth_login():
        if request.method == "GET":
            return jsonify({
                "info": "Login and receive a session token.",
                "required_fields": {"username": "string", "password": "string"},
                "example": {"username": "john_doe", "password": "secure123"},
                "response": {
                    "success": True,
                    "token":   "abc123...",
                    "user_id": "uuid",
                    "username":"john_doe",
                    "full_name":"John Doe",
                    "expertise_level": "tourist"
                },
                "note": "Use the returned token as: Authorization: Bearer <token>"
            }), 200
        if not chatbot.auth:
            return jsonify({"success": False, "error": "Auth not initialized"}), 503
        try:
            data   = request.get_json(force=True, silent=True) or {}
            result = chatbot.auth.login(
                username = data.get("username", ""),
                password = data.get("password", "")
            )
            status = 200 if result["success"] else 401
            return jsonify(result), status
        except Exception as e:
            return jsonify({"success": False, "error": str(e)}), 500

    # ── POST /auth/logout ─────────────────────────────────────────────────────
    @app.route("/auth/logout", methods=["POST"])
    def auth_logout():
        if not chatbot.auth:
            return jsonify({"success": False, "error": "Auth not initialized"}), 503
        token, _ = _get_token_user(request)
        if not token:
            return jsonify({"success": False, "error": "No token provided"}), 400
        return jsonify(chatbot.auth.logout(token))

    # ── GET /auth/me ──────────────────────────────────────────────────────────
    @app.route("/auth/me", methods=["GET"])
    def auth_me():
        if not chatbot.auth:
            return jsonify({"success": False, "error": "Auth not initialized"}), 503
        token, session_info = _get_token_user(request)
        if not session_info:
            return jsonify({"success": False, "error": "Invalid or missing token"}), 401
        profile = chatbot.auth.get_user_profile(session_info["username"])
        hist_stats = chatbot.history_mgr.get_stats(session_info["username"]) if chatbot.history_mgr else {}
        return jsonify({
            "success":    True,
            "profile":    profile,
            "chat_stats": hist_stats,
            "timestamp":  datetime.now().isoformat()
        })

    # ── PUT /auth/profile ─────────────────────────────────────────────────────
    @app.route("/auth/profile", methods=["PUT", "POST"])
    def auth_update_profile():
        if not chatbot.auth:
            return jsonify({"success": False, "error": "Auth not initialized"}), 503
        token, session_info = _get_token_user(request)
        if not session_info:
            return jsonify({"success": False, "error": "Unauthorized"}), 401
        try:
            data   = request.get_json(force=True, silent=True) or {}
            result = chatbot.auth.update_profile(session_info["username"], data)
            return jsonify(result)
        except Exception as e:
            return jsonify({"success": False, "error": str(e)}), 500

