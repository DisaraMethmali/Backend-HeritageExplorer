            gr.Button("Upload Adapter", variant="secondary").click(do_upload, [hf_tok], up_out)

        # ── Download Report tab ─────────────────────────────────────────────────────────
        with gr.Tab("📄 Download Report"):
            gr.Markdown("""
            ### Download Your Personalised History Report
            Your conversations with the historical characters are compiled into a
            beautiful PDF — one rich paragraph per topic you explored.

            **Step 1:** Log in using the **Register / Login** tab.
            **Step 2:** Your token fills in here automatically.
            **Step 3:** Choose a filter and click **Generate Report Link**.
            **Step 4:** Click the gold download button.
            """)
            with gr.Row():
                rpt_token = gr.Textbox(
                    label="Session Token (auto-filled after login)",
                    placeholder="Log in first — token appears here automatically",
                    interactive=True, scale=3,
                )
                rpt_location = gr.Dropdown(
                    choices=[
                        ("All topics (Temple + Galle)", "all"),
                        ("Temple of the Tooth only",    "temple"),
                        ("Galle Fort only",             "galle"),
                    ],
                    value="all", label="Location Filter", scale=1,
                )
            rpt_btn    = gr.Button("Generate Report Link", variant="primary")
            rpt_status = gr.Markdown(label="Status")
            rpt_link   = gr.HTML(label="Download Link")

            # Auto-fill token when user logs in
            login_token.change(fn=lambda t: t, inputs=[login_token], outputs=[rpt_token])

            def build_report_link(token, location):
                import urllib.request
                import json as _json
                import socket as _sock
                token = (token or "").strip()
                if not token:
                    return (
                        "⚠️ **No token found.**  "
                        "Please log in first in the **Register / Login** tab.",
                        ""
                    )
                # Find which port Flask is listening on
                flask_url = None
                for port in range(5000, 5020):
                    try:
                        with _sock.create_connection(("127.0.0.1", port), timeout=1):
                            flask_url = f"http://localhost:{port}"
                            break
                    except OSError:
                        continue
                if not flask_url:
                    return ("⚠️ Flask API not reachable. Is the server running?", "")

                # Call /report/preview to validate token and get topic summary
                preview_url = f"{flask_url}/report/preview?token={token}"
                try:
                    with urllib.request.urlopen(preview_url, timeout=8) as resp:
                        data = _json.loads(resp.read().decode())
                except urllib.error.HTTPError as e:
                    body = e.read().decode()
                    try:
                        msg = _json.loads(body).get("error", body)
                    except Exception:
                        msg = body
                    if e.code == 401:
                        return (
                            "🔒 **Unauthorized** — token expired or invalid.\n\n"
                            "Please log in again in the **Register / Login** tab.",
                            ""
                        )
                    return (f"❌ **Server error {e.code}:** {msg}", "")
                except Exception as ex:
                    return (f"❌ **Connection error:** {ex}", "")

                if not data.get("success"):
                    return (f"❌ {data.get('error', 'Unknown error')}", "")

                username   = data.get("username", "you")
                total_msgs = data.get("total_messages", 0)
                topics     = data.get("topics_explored", {})
                dl_urls    = data.get("download_urls", {})

                if total_msgs == 0:
                    return (
                        f"ℹ️ **No chat history yet** for `{username}`.\n\n"
                        "Start chatting in the **Chat** tab first, then return here.",
                        ""
                    )

                loc_key = location if location in ("temple", "galle") else "all"
                dl_url  = dl_urls.get(loc_key) or f"/report/user?location={loc_key}&token={token}"
                if dl_url.startswith("/"):
                    dl_url = flask_url + dl_url

                topic_lines = "\n".join(
                    f"  - **{t}**: {c} question{'s' if c != 1 else ''}"
                    for t, c in sorted(topics.items(), key=lambda x: -x[1])
                )
                status_md = (
                    f"✅ **Report ready for `{username}`**\n\n"
                    f"**{total_msgs} messages** across your conversations\n\n"
                    f"**Topics in your report:**\n{topic_lines}\n\n"
                    f"👇 Click the button below to download your PDF."
                )
                link_html = (
                    "<div style=\"margin-top:16px;padding:20px;background:#1e293b;"
                    "border-radius:12px;border:1px solid #334155;text-align:center\">"
                    "<p style=\"color:#94a3b8;margin:0 0 14px 0;font-size:14px\">"
                    "Your personalised Sri Lanka history report is ready</p>"
                    f"<a href=\"{dl_url}\" target=\"_blank\" "
                    "style=\"display:inline-block;padding:12px 32px;"
                    "background:linear-gradient(135deg,#C9A84C,#f59e0b);"
                    "color:#1a1a1a;border-radius:8px;font-weight:bold;"
                    "font-size:16px;text-decoration:none;"
                    "box-shadow:0 4px 12px rgba(201,168,76,0.4)\">"
                    "⬇ Download PDF Report</a>"
                    f"<p style=\"color:#475569;margin:12px 0 0 0;font-size:12px\">"
                    f"Filter: <strong style=\"color:#cbd5e1\">{loc_key.title()}</strong>"
                    f" &nbsp;|&nbsp; User: <strong style=\"color:#cbd5e1\">{username}</strong>"
                    "</p></div>"
                )
                return status_md, link_html

            rpt_btn.click(
                fn=build_report_link,
                inputs=[rpt_token, rpt_location],
                outputs=[rpt_status, rpt_link],
            )

        # ── Tab 14: Analytics ─────────────────────────────────────────────────
        with gr.Tab("Analytics"):
            with gr.Row():
                a_plot = gr.Plot(label="User Analytics")
                t_plot = gr.Plot(label="Training Loss")
            gr.Button("Refresh All").click(
                lambda: (create_analytics_viz(chatbot.metrics),
                         create_training_viz(chatbot.metrics)),
                outputs=[a_plot, t_plot]
            )

        # ── Tab 15: User Profile ──────────────────────────────────────────────
        with gr.Tab("User Profile"):
            p_sid  = gr.Textbox(label="Session ID", value="user_1")
            p_disp = gr.Code(label="Profile (JSON)", language="json")
            gr.Button("Load Profile").click(
                lambda s: json.dumps(chatbot.profiles.get_profile(s), indent=2),
                [p_sid], [p_disp]
            )

        # ── Tab 16: Register / Login ──────────────────────────────────────────
        with gr.Tab("Register / Login"):
            gr.Markdown("""
            ### User Registration & Login
            Create an account to save your chat history, quiz XP scores, and preferences permanently.
            All sessions are tied to your username after login.
            """)

            with gr.Tab("Register"):
                gr.Markdown("#### Create a new account")
                with gr.Row():
                    reg_username  = gr.Textbox(label="Username (letters, numbers, _ only)", placeholder="e.g. john_doe")
                    reg_email     = gr.Textbox(label="Email", placeholder="you@example.com")
                with gr.Row():
                    reg_fullname  = gr.Textbox(label="Full Name", placeholder="John Doe")
                    reg_password  = gr.Textbox(label="Password (min 6 chars)", type="password")
                with gr.Row():
                    reg_age       = gr.Dropdown(choices=["child","teen","adult","senior"], value="adult", label="Age Group")
                    reg_expertise = gr.Dropdown(choices=["child","student","researcher","tourist"], value="tourist", label="Expertise Level")
                reg_out = gr.Markdown(label="Result")
                def do_register(username, email, fullname, password, age, expertise):
                    if not chatbot.auth:
                        return "Auth system not initialized."
                    result = chatbot.auth.register(username, email, password, fullname, age, expertise)
                    if result["success"]:
                        return (f"**Registration successful!**\n\n"
                                f"Username: `{result['username']}`\n{result['message']}\n\n"
                                f"You can now log in using the Login tab.")
                    return f"**Error:** {result['error']}"
                gr.Button("Register", variant="primary").click(
                    do_register,
                    [reg_username, reg_email, reg_fullname, reg_password, reg_age, reg_expertise],
                    reg_out
                )

            with gr.Tab("Login"):
                gr.Markdown("#### Login to your account")
                with gr.Row():
                    login_username = gr.Textbox(label="Username")
                    login_password = gr.Textbox(label="Password", type="password")
                login_out   = gr.Markdown(label="Result")
                login_token = gr.Textbox(label="Your Session Token (copy this for API calls)", interactive=False)
                def do_login(username, password):
                    if not chatbot.auth:
                        return "Auth system not initialized.", ""
                    result = chatbot.auth.login(username, password)
                    if result["success"]:
                        # Apply user expertise level to chatbot session
                        chatbot.expertise_adapter.set_user_level(username, result.get("expertise_level","tourist"))
                        current_token["value"] = result["token"]  # save for Report tab
                        return (
                            f"**Login successful!**\n\n"
                            f"Welcome, **{result.get('full_name') or result['username']}**!\n\n"
                            f"Expertise level: `{result.get('expertise_level','tourist')}`\n\n"
                            f"Token saved — go to the **📄 Download Report** tab to get your PDF.\n\n"
                            f"To use with the API: `Authorization: Bearer <your-token>`"
                        ), result["token"]
                    return f"**Error:** {result['error']}", ""
                gr.Button("Login", variant="primary").click(
                    do_login, [login_username, login_password], [login_out, login_token]
                )
                gr.Markdown("> After login, your token is shown above. Use it in other tabs to access your data.")

            with gr.Tab("My Account"):
                gr.Markdown("#### Your profile, stats, and preferences")
                with gr.Row():
                    acct_username = gr.Textbox(label="Username")
                    acct_token    = gr.Textbox(label="Session Token", type="password")
                with gr.Row():
                    acct_profile  = gr.Code(label="Your Profile (JSON)", language="json")
                    acct_stats    = gr.Markdown(label="Activity Stats")
                def load_account(username, token):
                    if not chatbot.auth:
                        return "{}", "Auth not initialized"
                    session = chatbot.auth.verify_token(token)
                    if not session or session["username"] != username.strip().lower():
                        return "{}", "**Invalid token or username mismatch.** Please log in first."
                    profile = chatbot.auth.get_user_profile(username.strip().lower())
                    hist_stats = chatbot.history_mgr.get_stats(username.strip().lower()) if chatbot.history_mgr else {}
                    quiz_lb = chatbot.quiz_engine.session_scores.get(username.strip().lower(), {})
                    lines = [
                        f"### Activity Stats for `{username}`",
                        f"**Chat History:**",
                        f"- Total messages: {hist_stats.get('total_messages', 0)}",
                        f"- Unique sessions: {hist_stats.get('sessions', 0)}",
                        f"- Avg response confidence: {hist_stats.get('avg_confidence', 0):.2%}",
                        f"- First message: {hist_stats.get('first_message','—')[:16].replace('T',' ') if hist_stats.get('first_message') else '—'}",
                        f"- Last message: {hist_stats.get('last_message','—')[:16].replace('T',' ') if hist_stats.get('last_message') else '—'}",
                    ]
                    if hist_stats.get("characters"):
                        lines.append("\n**Favourite Characters:**")
                        for char, cnt in sorted(hist_stats["characters"].items(), key=lambda x: -x[1]):
                            lines.append(f"- {CHARACTERS.get(char,{}).get('name',char)}: {cnt} messages")
                    if hist_stats.get("topics"):
                        top_topics = sorted(hist_stats["topics"].items(), key=lambda x: -x[1])[:5]
                        lines.append("\n**Top Topics:**")
                        for topic, cnt in top_topics:
                            lines.append(f"- {topic}: {cnt} questions")
                    if quiz_lb:
                        lines.append(f"\n**Quiz XP:** {quiz_lb.get('xp',0)} XP | Accuracy: {quiz_lb.get('correct',0)}/{quiz_lb.get('total',1)}")
                    return json.dumps(profile, indent=2), "\n".join(lines)
                gr.Button("Load My Profile & Stats", variant="primary").click(
                    load_account, [acct_username, acct_token], [acct_profile, acct_stats]
                )
                gr.Markdown("---")
                gr.Markdown("**Update Expertise Level:**")
                with gr.Row():
                    upd_level   = gr.Dropdown(choices=["child","student","researcher","tourist"], value="tourist", label="New Level")
                    upd_token2  = gr.Textbox(label="Session Token", type="password")
                    upd_user2   = gr.Textbox(label="Username")
                upd_out = gr.Markdown(label="Update Result")
                def update_expertise(level, token, username):
                    if not chatbot.auth:
                        return "Auth not initialized"
                    session = chatbot.auth.verify_token(token)
                    if not session or session["username"] != username.strip().lower():
                        return "Invalid token."
                    chatbot.auth.update_profile(username.strip().lower(), {"expertise_level": level})
                    chatbot.expertise_adapter.set_user_level(username.strip().lower(), level)
                    return f"Updated expertise to **{level}**. Chat answers will now adapt accordingly."
                gr.Button("Update Level", variant="secondary").click(
                    update_expertise, [upd_level, upd_token2, upd_user2], upd_out
                )

            with gr.Tab("Change Password"):
                gr.Markdown("#### Change your account password")
                with gr.Row():
                    pwd_username  = gr.Textbox(label="Username")
                    pwd_old       = gr.Textbox(label="Current Password", type="password")
                with gr.Row():
                    pwd_new       = gr.Textbox(label="New Password (min 6 chars)", type="password")
                    pwd_confirm   = gr.Textbox(label="Confirm New Password", type="password")
                pwd_out = gr.Markdown(label="Result")
                def change_password(username, old_pwd, new_pwd, confirm_pwd):
                    if not chatbot.auth:
                        return "Auth not initialized."
                    if new_pwd != confirm_pwd:
                        return "**Error:** New passwords do not match."
                    result = chatbot.auth.change_password(username.strip().lower(), old_pwd, new_pwd)
                    if result["success"]:
                        return f"**Password changed successfully!**"
                    return f"**Error:** {result['error']}"
                gr.Button("Change Password", variant="primary").click(
                    change_password, [pwd_username, pwd_old, pwd_new, pwd_confirm], pwd_out
                )

        # ── Tab 17: Chat History ──────────────────────────────────────────────
        with gr.Tab("Chat History"):
            gr.Markdown("""
            ### Your Complete Chat History
            View, search, and filter all your conversations with historical characters.
            Login first in the Register / Login tab to access your history.
            """)
            with gr.Row():
                hist_username     = gr.Textbox(label="Username", value="user_1")
                hist_token        = gr.Textbox(label="Session Token (optional for session-only view)", type="password")
            with gr.Row():
                hist_char_filter  = gr.Dropdown(
                    choices=["all"] + list(CHARACTERS.keys()), value="all", label="Filter by Character"
                )
                hist_topic_filter = gr.Dropdown(
                    choices=["all","king","temple","festival","kingdom","buddhism","fort","trade","colonial","general"],
                    value="all", label="Filter by Topic"
                )
            with gr.Row():
                hist_search       = gr.Textbox(label="Search (keywords in Q&A)", placeholder="e.g. Tooth Relic, Perahera")
                hist_limit        = gr.Slider(5, 100, value=20, step=5, label="Max Results")
            with gr.Row():
                hist_date_from    = gr.Textbox(label="Date From (YYYY-MM-DD, optional)", placeholder="2025-01-01")
                hist_date_to      = gr.Textbox(label="Date To (YYYY-MM-DD, optional)", placeholder="2026-12-31")

            hist_load_btn = gr.Button("Load History", variant="primary")
            with gr.Row():
                hist_out          = gr.Markdown(label="Chat History")
                hist_sessions_out = gr.Markdown(label="Sessions Summary")

            def load_history(username, token, char_filter, topic_filter, search, limit, date_from, date_to):
                if not chatbot.history_mgr:
                    return "History manager not initialized.", ""
                uname = username.strip().lower()
                # Verify token if provided
                if token and token.strip() and chatbot.auth:
                    session = chatbot.auth.verify_token(token.strip())
                    if not session or session["username"] != uname:
                        return "**Invalid token.** History access denied.", ""

                result = chatbot.history_mgr.get_history(
                    username     = uname,
                    character_id = None if char_filter == "all" else char_filter,
                    topic        = None if topic_filter == "all" else topic_filter,
                    search       = search.strip() if search.strip() else None,
                    limit        = int(limit),
                    date_from    = date_from.strip() if date_from.strip() else None,
                    date_to      = date_to.strip() if date_to.strip() else None,
                )
                records = result["records"]
                if not records:
                    return (f"No history found matching your filters.\n\n"
                            f"Total messages in database for this user: {result['total']}"), ""

                lines = [f"**{result['returned']} of {result['total']} messages** (most recent first)", "---"]
                for r in records:
                    ts   = r["timestamp"][:16].replace("T", " ")
                    conf = r.get("confidence", 0)
                    lines.append(f"**[{ts}]** `{r['character_name']}` | Topic: `{r['topic']}` | Intent: `{r.get('intent','?')}` | Confidence: {conf:.0%}")
                    lines.append(f"> **Q:** {r['question']}")
                    ans = r["answer"]
                    lines.append(f"> **A:** {ans[:400]}{'...' if len(ans) > 400 else ''}")
                    lines.append("")

                # Sessions summary
                sessions = chatbot.history_mgr.get_session_list(uname)
                stats    = chatbot.history_mgr.get_stats(uname)
                sess_lines = [
                    f"### {len(sessions)} Sessions | {stats.get('total_messages',0)} Total Messages",
                    ""
                ]
                for s in sessions[:15]:
                    last = s["last_message"][:16].replace("T"," ")
                    chars = ", ".join(s.get("characters_used",[]))
                    sess_lines.append(f"**`{s['session_id']}`**")
                    sess_lines.append(f"  - Messages: {s['message_count']} | Last: {last}")
                    sess_lines.append(f"  - Characters: {chars}")
                    sess_lines.append(f"  - Topics: {', '.join(s.get('topics',[])[:4])}")
                    sess_lines.append("")

                return "\n".join(lines), "\n".join(sess_lines)

            hist_load_btn.click(
                load_history,
                [hist_username, hist_token, hist_char_filter, hist_topic_filter,
                 hist_search, hist_limit, hist_date_from, hist_date_to],
                [hist_out, hist_sessions_out]
            )

            gr.Markdown("---")
            with gr.Row():
                with gr.Column():
                    gr.Markdown("**Export History as JSON:**")
                    export_user  = gr.Textbox(label="Username")
                    export_token = gr.Textbox(label="Token", type="password")
                    export_out   = gr.Code(label="Exported JSON", language="json")
                    def export_history(username, token):
                        if not chatbot.history_mgr:
                            return "[]"
                        if token and token.strip() and chatbot.auth:
                            session = chatbot.auth.verify_token(token.strip())
                            if not session or session["username"] != username.strip().lower():
                                return json.dumps({"error": "Invalid token"})
                        records = chatbot.history_mgr.export_history(username.strip().lower())
                        return json.dumps(records, indent=2)
                    gr.Button("Export All History", variant="secondary").click(
                        export_history, [export_user, export_token], export_out
                    )

                with gr.Column():
                    gr.Markdown("**Delete a Session's History:**")
                    del_username  = gr.Textbox(label="Username")
                    del_token     = gr.Textbox(label="Token", type="password")
                    del_session   = gr.Textbox(label="Session ID to delete")
                    del_out       = gr.Textbox(label="Result", interactive=False)
                    def del_session_history(username, token, session_id):
                        if not chatbot.history_mgr:
                            return "History manager not initialized."
                        if token.strip() and chatbot.auth:
                            session = chatbot.auth.verify_token(token.strip())
                            if not session or session["username"] != username.strip().lower():
                                return "Invalid token."
                        if not session_id.strip():
                            return "Enter a session ID."
                        result = chatbot.history_mgr.delete_session(username.strip().lower(), session_id.strip())
                        return f"Deleted {result['deleted_messages']} messages from session `{session_id.strip()}`."
                    gr.Button("Delete Session", variant="stop").click(
                        del_session_history, [del_username, del_token, del_session], del_out
                    )

    return demo




# =============================================================================
# FLASK REST API
# =============================================================================

# ── Shared helper — ask one OR all characters, return structured replies ──────

def _ask_characters(chatbot, query: str, character_ids: list,
                    session_id: str = "default") -> list:
    """
    Query each character and return a list of reply objects.
    Pass character_ids=["all"] to get replies from all 4 characters at once.
    Each reply contains: character_id, character_name, title,
    question, answer, confidence, intent, topic, retrieval_time, total_time.
    """
    # Expand "all" shorthand
    if character_ids == ["all"] or character_ids == ["ALL"]:
        character_ids = list(CHARACTERS.keys())          # king, nilame, dutch, citizen

    replies = []
    for cid in character_ids:
        if cid not in CHARACTERS:
            replies.append({
                "character_id": cid,
                "error": f"Unknown character_id '{cid}'. "
                         f"Valid values: {', '.join(CHARACTERS.keys())}"
            })
            continue
        resp = chatbot.generate_answer(query, cid, session_id)
        replies.append({
            "character_id":   cid,
            "character_name": CHARACTERS[cid]["name"],
            "title":          CHARACTERS[cid]["title"],
            "question":       query,
            "answer":         resp.get("answer", ""),
            "confidence":     resp.get("confidence"),
            "intent":         resp.get("intent"),
            "topic":          resp.get("topic"),
            "retrieval_time": resp.get("retrieval_time"),
            "total_time":     resp.get("total_time"),
        })
    return replies

_admin_sessions: dict = {}

def _check_admin_token(req) -> bool:
    auth = req.headers.get("Authorization", "")
    if auth.startswith("Bearer "):
        return auth[7:].strip() in _admin_sessions
    return False

def create_flask_api(chatbot: MultiCharacterChatbot) -> Flask:
    app = Flask(__name__)
    CORS(app)
 
    # ── / — browser index ─────────────────────────────────────────────────────
    @app.route("/", methods=["GET"])
    def index():
        html = """<!DOCTYPE html><html><head>
        <title>Sri Lanka Chatbot API</title>
        <style>
          body{font-family:Arial,sans-serif;max-width:900px;margin:40px auto;padding:20px}
          h1{color:#2c3e50}h2{color:#34495e}
          table{border-collapse:collapse;width:100%}
          th,td{border:1px solid #ddd;padding:10px;text-align:left;vertical-align:top}
          th{background:#3498db;color:#fff}tr:nth-child(even){background:#f9f9f9}
          code,pre{background:#f0f0f0;padding:2px 6px;border-radius:3px;font-size:13px}
          pre{padding:12px;overflow-x:auto}.post{color:#e67e22;font-weight:bold}
          .get{color:#27ae60;font-weight:bold}.badge{display:inline-block;
          padding:2px 8px;border-radius:4px;font-size:12px;font-weight:bold;color:#fff}
          .b-get{background:#27ae60}.b-post{background:#e67e22}
        </style></head><body>
        <h1>&#127981; Sri Lanka Historical Chatbot — REST API</h1>
        <p>Model: <code>TinyLlama/TinyLlama-1.1B-Chat-v1.0</code> &nbsp;|&nbsp;
           Characters: <code>king</code> <code>nilame</code> <code>dutch</code> <code>citizen</code></p>

        <h2>Endpoints</h2>
        <table>
          <tr><th>Method</th><th>URL</th><th>Description</th></tr>
          <tr><td><span class="badge b-get">GET</span></td>
              <td><a href="/health">/health</a></td>
              <td>System status</td></tr>
          <tr><td><span class="badge b-get">GET</span></td>
              <td><a href="/api/characters">/api/characters</a></td>
              <td>List all 4 characters with their details</td></tr>
          <tr><td><span class="badge b-get">GET</span></td>
              <td><a href="/api/metrics">/api/metrics</a></td>
              <td>All system metrics</td></tr>
          <tr><td><span class="badge b-get">GET</span></td>
              <td>/api/profile/&lt;session_id&gt;</td>
              <td>User profile &amp; history</td></tr>
          <tr><td><span class="badge b-post">POST</span></td>
              <td>/chat</td>
              <td>Chat with <b>one</b> character (RAG pipeline)<br>
                  Body: <code>{"query":"...", "character_id":"king", "session_id":"user_1"}</code></td></tr>
          <tr><td><span class="badge b-post">POST</span></td>
              <td>/chat/all</td>
              <td>Ask <b>all 4 characters at once</b> — returns array of 4 replies<br>
                  Body: <code>{"query":"...", "session_id":"user_1"}</code></td></tr>
          <tr><td><span class="badge b-post">POST</span></td>
              <td>/chat/multi</td>
              <td>Ask a <b>custom list</b> of characters<br>
                  Body: <code>{"query":"...", "character_ids":["king","dutch"], "session_id":"user_1"}</code></td></tr>
          <tr><td><span class="badge b-post">POST</span></td>
              <td>/generate</td>
              <td>Direct generation, no RAG<br>
                  Body: <code>{"prompt":"...", "character_id":"nilame"}</code></td></tr>
          <tr><td><span class="badge b-post">POST</span></td>
              <td>/generate/all</td>
              <td>Direct generation from <b>all 4 characters</b><br>
                  Body: <code>{"prompt":"..."}</code></td></tr>
          <tr><td><span class="badge b-post">POST</span></td>
              <td>/api/feedback</td>
              <td>Submit RL feedback<br>
                  Body: <code>{"query":"...", "rating":5, "character_id":"king", "session_id":"user_1"}</code></td></tr>
        </table>

        <h2>Quick examples</h2>
        <h3>One character</h3>
        <pre>curl -X POST http://localhost:5000/chat \
  -H "Content-Type: application/json" \
  -d '{"query": "Tell me about the Sacred Tooth Relic", "character_id": "king", "session_id": "user_1"}'</pre>

        <h3>All 4 characters at once</h3>
        <pre>curl -X POST http://localhost:5000/chat/all \
  -H "Content-Type: application/json" \
  -d '{"query": "What is the Esala Perahera?", "session_id": "user_1"}'</pre>

        <h3>Two specific characters</h3>
        <pre>curl -X POST http://localhost:5000/chat/multi \
  -H "Content-Type: application/json" \
  -d '{"query": "Tell me about Galle Fort", "character_ids": ["dutch", "citizen"], "session_id": "user_1"}'</pre>
        </body></html>"""
        return html, 200, {"Content-Type": "text/html"}

    # ── /health ────────────────────────────────────────────────────────────────
    @app.route("/health", methods=["GET"])
    def health():
        return jsonify({
            "status":       "healthy",
            "base_model":   CONFIG["base_model"],
            "adapter_repo": CONFIG["adapter_repo"],
            "model_loaded": chatbot.model is not None,
            "characters":   {
                cid: {"name": c["name"], "title": c["title"]}
                for cid, c in CHARACTERS.items()
            },
            "device":       "cuda" if torch.cuda.is_available() else "cpu",
            "timestamp":    datetime.now().isoformat()
        })

    @app.route("/api/health", methods=["GET"])
    def api_health():
        return health()

    # ── /chat — single character ───────────────────────────────────────────────
    @app.route("/chat", methods=["GET", "POST"])
    def chat():
        if request.method == "GET":
            return jsonify({
                "info": "POST with JSON body. Use /chat/all for all 4 characters at once.",
                "required_fields": {"query": "string", "character_id": "king|nilame|dutch|citizen"},
                "optional_fields": {"session_id": "string (default: default)"},
                "example": {"query": "Tell me about the Tooth Relic",
                            "character_id": "king", "session_id": "user_1"}
            }), 200

        try:
            data       = request.get_json(force=True, silent=True) or {}
            query      = data.get("query") or data.get("question", "")
            char_id    = data.get("character_id", "king")
            session_id = data.get("session_id", "default")

            if not query:
                return jsonify({"error": "'query' field is required"}), 400
            if char_id not in CHARACTERS:
                return jsonify({
                    "error": f"Unknown character_id '{char_id}'",
                    "valid_character_ids": list(CHARACTERS.keys())
                }), 400

            replies = _ask_characters(chatbot, query, [char_id], session_id)
            reply   = replies[0]

            return jsonify({
                "success":      True,
                "character_id": char_id,
                "character_name": CHARACTERS[char_id]["name"],
                "title":        CHARACTERS[char_id]["title"],
                "question":     query,
                "answer":       reply.get("answer"),
                "confidence":   reply.get("confidence"),
                "intent":       reply.get("intent"),
                "topic":        reply.get("topic"),
                "session_id":   session_id,
                "timestamp":    datetime.now().isoformat()
            })
        except Exception as e:
            return jsonify({"success": False, "error": str(e)}), 500

    @app.route("/api/chat", methods=["GET", "POST"])
    def api_chat():
        return chat()

    # ── /chat/all — ALL 4 characters reply ────────────────────────────────────
    @app.route("/chat/all", methods=["GET", "POST"])
    def chat_all():
        """Ask all 4 characters the same question and return all 4 answers."""
        if request.method == "GET":
            return jsonify({
                "info": "POST a query — all 4 characters will reply.",
                "required_fields": {"query": "string"},
                "optional_fields": {"session_id": "string"},
                "example": {"query": "What is the Sacred Tooth Relic?",
                            "session_id": "user_1"}
            }), 200

        try:
            data       = request.get_json(force=True, silent=True) or {}
            query      = data.get("query") or data.get("question", "")
            session_id = data.get("session_id", "default")

            if not query:
                return jsonify({"error": "'query' field is required"}), 400

            replies = _ask_characters(chatbot, query, list(CHARACTERS.keys()), session_id)

            return jsonify({
                "success":       True,
                "question":      query,
                "session_id":    session_id,
                "total_replies": len(replies),
                "replies":       replies,
                "timestamp":     datetime.now().isoformat()
            })
        except Exception as e:
            return jsonify({"success": False, "error": str(e)}), 500

    # ── /chat/multi — custom list of characters ────────────────────────────────
    @app.route("/chat/multi", methods=["GET", "POST"])
    def chat_multi():
        """Ask a specific subset of characters."""
        if request.method == "GET":
            return jsonify({
                "info": "POST with a list of character_ids to query.",
                "required_fields": {
                    "query": "string",
                    "character_ids": "list e.g. [king, dutch] or [all]"
                },
                "optional_fields": {"session_id": "string"},
                "valid_character_ids": list(CHARACTERS.keys()),
                "example": {"query": "Tell me about the colonial period",
                            "character_ids": ["dutch", "citizen"],
                            "session_id": "user_1"}
            }), 200

        try:
            data          = request.get_json(force=True, silent=True) or {}
            query         = data.get("query") or data.get("question", "")
            character_ids = data.get("character_ids", list(CHARACTERS.keys()))
            session_id    = data.get("session_id", "default")

            if not query:
                return jsonify({"error": "'query' field is required"}), 400
            if not isinstance(character_ids, list) or len(character_ids) == 0:
                return jsonify({
                    "error": "'character_ids' must be a non-empty list",
                    "valid_character_ids": list(CHARACTERS.keys())
                }), 400

            # Support shorthand "all"
            if "all" in character_ids:
                character_ids = list(CHARACTERS.keys())

            replies = _ask_characters(chatbot, query, character_ids, session_id)

            return jsonify({
                "success":          True,
                "question":         query,
                "session_id":       session_id,
                "characters_asked": character_ids,
                "total_replies":    len(replies),
                "replies":          replies,
                "timestamp":        datetime.now().isoformat()
            })
        except Exception as e:
            return jsonify({"success": False, "error": str(e)}), 500

    # ── /generate — single character, no RAG ──────────────────────────────────
    @app.route("/generate", methods=["GET", "POST"])
    def generate():
        if request.method == "GET":
            return jsonify({
                "info": "Direct generation (no RAG pipeline). Use /generate/all for all chars.",
                "required_fields": {"prompt": "string"},
                "optional_fields": {
                    "character_id": "king|nilame|dutch|citizen (default: citizen)",
                    "max_tokens": "int (default: 2000000)"
                },
                "example": {"prompt": "What is Galle Fort?", "character_id": "dutch"}
            }), 200

        try:
            data    = request.get_json(force=True, silent=True) or {}
            prompt  = data.get("prompt", "")
            char_id = data.get("character_id", "citizen")
            max_tok = int(data.get("max_tokens", CONFIG["max_new_tokens"]))

            if not prompt:
                return jsonify({"error": "'prompt' field is required"}), 400
            if char_id not in CHARACTERS:
                return jsonify({
                    "error": f"Unknown character_id '{char_id}'",
                    "valid_character_ids": list(CHARACTERS.keys())
                }), 400

            char   = CHARACTERS[char_id]
            system = (f"You are {char['name']}, {char['title']}. "
                      f"{char['personality']}. Respond about Sri Lankan history.")
            fmt = (
                f"<|system|>\n{system}</s>\n"
                f"<|user|>\n{prompt}</s>\n<|assistant|>\n"
            )

            inputs = chatbot.tokenizer(fmt, return_tensors="pt",
                                        truncation=True, max_length=CONFIG["max_length"])
            if torch.cuda.is_available():
                inputs = {k: v.to(chatbot.model.device) for k, v in inputs.items()}

            with torch.no_grad():
                out = chatbot.model.generate(
                    **inputs, max_new_tokens=max_tok,
                    temperature=CONFIG["temperature"], top_p=CONFIG["top_p"],
                    repetition_penalty=CONFIG["repetition_penalty"], do_sample=True,
                    pad_token_id=chatbot.tokenizer.pad_token_id,
                    eos_token_id=chatbot.tokenizer.eos_token_id
                )

            decoded = chatbot.tokenizer.decode(out[0], skip_special_tokens=True)
            if "<|assistant|>" in decoded:
                response = decoded.split("<|assistant|>")[-1].strip().split("\n\n")[0]
            else:
                response = decoded[len(fmt):].strip().split("\n\n")[0]

            return jsonify({
                "success":        True,
                "character_id":   char_id,
                "character_name": char["name"],
                "title":          char["title"],
                "prompt":         prompt,
                "response":       response,
                "timestamp":      datetime.now().isoformat()
            })
        except Exception as e:
            return jsonify({"success": False, "error": str(e)}), 500

    # ── /generate/all — all 4 characters, no RAG ──────────────────────────────
    @app.route("/generate/all", methods=["GET", "POST"])
    def generate_all():
        """Direct generation from all 4 characters — no RAG."""
        if request.method == "GET":
            return jsonify({
                "info": "POST a prompt — all 4 characters respond (no RAG).",
                "required_fields": {"prompt": "string"},
                "optional_fields": {"max_tokens": "int (default: 20000)"},
                "example": {"prompt": "Tell me about Sri Lanka", "max_tokens": 15000}
            }), 200

        try:
            data    = request.get_json(force=True, silent=True) or {}
            prompt  = data.get("prompt", "")
            max_tok = int(data.get("max_tokens", CONFIG["max_new_tokens"]))

            if not prompt:
                return jsonify({"error": "'prompt' field is required"}), 400

            replies = []
            for cid, char in CHARACTERS.items():
                system = (f"You are {char['name']}, {char['title']}. "
                          f"{char['personality']}. Respond about Sri Lankan history.")
                fmt = (
                    f"<|system|>\n{system}</s>\n"
                    f"<|user|>\n{prompt}</s>\n<|assistant|>\n"
                )
                inputs = chatbot.tokenizer(fmt, return_tensors="pt",
                                            truncation=True, max_length=CONFIG["max_length"])
                if torch.cuda.is_available():
                    inputs = {k: v.to(chatbot.model.device) for k, v in inputs.items()}
                try:
                    with torch.no_grad():
                        out = chatbot.model.generate(
                            **inputs, max_new_tokens=max_tok,
                            temperature=CONFIG["temperature"], top_p=CONFIG["top_p"],
                            repetition_penalty=CONFIG["repetition_penalty"], do_sample=True,
                            pad_token_id=chatbot.tokenizer.pad_token_id,
                            eos_token_id=chatbot.tokenizer.eos_token_id
                        )
                    decoded = chatbot.tokenizer.decode(out[0], skip_special_tokens=True)
                    if "<|assistant|>" in decoded:
                        response = decoded.split("<|assistant|>")[-1].strip().split("\n\n")[0]
                    else:
                        response = decoded[len(fmt):].strip().split("\n\n")[0]
                    replies.append({
                        "character_id":   cid,
                        "character_name": char["name"],
                        "title":          char["title"],
                        "prompt":         prompt,
                        "response":       response
                    })
                except Exception as e:
                    replies.append({
                        "character_id": cid,
                        "character_name": char["name"],
                        "error": str(e)
                    })

            return jsonify({
                "success":       True,
                "prompt":        prompt,
                "total_replies": len(replies),
                "replies":       replies,
                "timestamp":     datetime.now().isoformat()
            })
        except Exception as e:
            return jsonify({"success": False, "error": str(e)}), 500

    # ── /api/feedback ──────────────────────────────────────────────────────────
    @app.route("/api/feedback", methods=["GET", "POST"])
    def feedback():
        if request.method == "GET":
            return jsonify({
                "info": "POST to submit RL feedback for a character response.",
                "required_fields": {"query": "string", "rating": "1-5"},
                "optional_fields": {
                    "character_id": "king|nilame|dutch|citizen",
                    "session_id":   "string"
                },
                "example": {"query": "What is the Esala Perahera?",
                            "rating": 5, "character_id": "nilame",
                            "session_id": "user_1"}
            }), 200

        try:
            data    = request.get_json(force=True, silent=True) or {}
            query   = data.get("query", "")
            rating  = data.get("rating", 0)
            char_id = data.get("character_id", "king")
            sid     = data.get("session_id", "default")

            if not query:
                return jsonify({"error": "'query' field is required"}), 400
            if not rating:
                return jsonify({"error": "'rating' field is required (1-5)"}), 400
            if char_id not in CHARACTERS:
                return jsonify({
                    "error": f"Unknown character_id '{char_id}'",
                    "valid_character_ids": list(CHARACTERS.keys())
                }), 400

            result = chatbot.provide_feedback(sid, char_id, query, float(rating))
            return jsonify({
                "success":        True,
                "character_id":   char_id,
                "character_name": CHARACTERS[char_id]["name"],
                "query":          query,
                "rating":         rating,
                "reward":         result.get("reward"),
                "epsilon":        result.get("epsilon"),
                "message":        result.get("message"),
                "timestamp":      datetime.now().isoformat()
            })
        except Exception as e:
            return jsonify({"success": False, "error": str(e)}), 500

