        },
        "galle_fort_ramparts": {
            "name": "Galle Fort Ocean Ramparts",
            "type": "colonial_site",
            "description": "Walk the 36-hectare fortified walls with panoramic ocean views.",
            "related_topics": ["fort", "colonial", "trade"],
            "related_characters": ["dutch"],
            "discovery_trigger": "After learning about Dutch Ceylon",
            "vr_experience": "Sunrise walk on the ramparts with Dutch VOC flags"
        },
        "perahera_route": {
            "name": "Esala Perahera Parade Route",
            "type": "cultural_site",
            "description": "The sacred route through Kandy streets used during the festival.",
            "related_topics": ["festival", "buddhism", "temple"],
            "related_characters": ["nilame"],
            "discovery_trigger": "After learning about the Esala Perahera",
            "vr_experience": "Night procession with 100 elephants, dancers, and drummers"
        },
        "kandy_palace_ruins": {
            "name": "Royal Palace of Kandy",
            "type": "royal_site",
            "description": "The ancient palace complex of the Kandyan kings, partially restored.",
            "related_topics": ["kingdom", "king"],
            "related_characters": ["king"],
            "discovery_trigger": "After learning about the Kandyan Kingdom",
            "vr_experience": "Throne room reconstruction of 1740s royal court"
        },
        "cinnamon_gardens": {
            "name": "Historic Cinnamon Gardens",
            "type": "trade_site",
            "description": "Where the Dutch VOC cultivated and peeled Ceylon cinnamon.",
            "related_topics": ["trade", "colonial"],
            "related_characters": ["dutch", "citizen"],
            "discovery_trigger": "After learning about Dutch cinnamon trade",
            "vr_experience": "Interactive cinnamon peeling demonstration with Salagama peelers"
        },
        "anuradhapura_stupas": {
            "name": "Ancient Stupas of Anuradhapura",
            "type": "ancient_site",
            "description": "Massive ancient Buddhist stupas built over 2000 years ago.",
            "related_topics": ["buddhism", "kingdom"],
            "related_characters": ["citizen"],
            "discovery_trigger": "After learning about ancient Sri Lankan history",
            "vr_experience": "Fly-over of ancient Anuradhapura at its peak glory (3rd century BCE)"
        }
    }

    def __init__(self):
        self.user_visited = defaultdict(set)
        print("VR Content Discovery Engine initialized")

    def suggest_sites(self, session_id: str, current_topic: str,
                      character_id: str, top_n: int = 3) -> List[Dict]:
        visited = self.user_visited[session_id]
        suggestions = []
        for site_id, site in self.VR_SITES.items():
            if site_id in visited:
                continue
            score = 0
            if current_topic in site["related_topics"]:
                score += 3
            if character_id in site["related_characters"]:
                score += 2
            if score > 0:
                suggestions.append({
                    "site_id": site_id,
                    "name": site["name"],
                    "type": site["type"],
                    "description": site["description"],
                    "vr_experience": site["vr_experience"],
                    "discovery_trigger": site["discovery_trigger"],
                    "relevance_score": score
                })
        suggestions.sort(key=lambda x: x["relevance_score"], reverse=True)
        return suggestions[:top_n]

    def mark_visited(self, session_id: str, site_id: str):
        self.user_visited[session_id].add(site_id)

    def get_all_sites(self) -> Dict:
        return self.VR_SITES


# =============================================================================
# ANOMALY EXPLANATION ENGINE
# Detects user misconceptions and provides context-aware clarification
# =============================================================================

class AnomalyExplanationEngine:
    COMMON_MISCONCEPTIONS = {
        "kandy_conquered": {
            "triggers": ["portuguese conquered kandy", "dutch took kandy", "europeans conquered kandy",
                         "kandy was conquered", "kandy fell to"],
            "correction": (
                "Actually, Kandy was NEVER conquered by the Portuguese or Dutch! "
                "This is a common misconception. The Portuguese made multiple failed attempts, "
                "and the Dutch controlled only the coastal regions. Kandy remained the only "
                "independent kingdom in Sri Lanka until 1815, when the British finally took "
                "it through a combination of diplomacy and internal political divisions — not military conquest."
            ),
            "severity": "high"
        },
        "actual_relic_in_procession": {
            "triggers": ["tooth relic is carried in procession", "actual tooth in perahera",
                         "real tooth paraded", "tooth relic walks through street"],
            "correction": (
                "A nuance worth knowing: during the Esala Perahera, the actual Tooth Relic does NOT "
                "leave the temple. What is carried in the procession is an ornate golden reliquary casket "
                "(a replica/representation). The actual Tooth Relic remains safely secured inside "
                "Sri Dalada Maligawa throughout the festival."
            ),
            "severity": "medium"
        },
        "dutch_built_galle": {
            "triggers": ["dutch built galle fort from scratch", "galle fort was dutch invention",
                         "dutch created galle fort"],
            "correction": (
                "Galle Fort was not built from scratch by the Dutch. The Portuguese actually built "
                "the original small fort in 1588. The Dutch significantly expanded and rebuilt it "
                "between 1663-1669, creating the massive fortification we see today. "
                "So it has Portuguese origins with Dutch expansion."
            ),
            "severity": "medium"
        },
        "sri_lanka_always_buddhist": {
            "triggers": ["sri lanka always buddhist", "always been buddhist", "buddhism always in lanka"],
            "correction": (
                "While Buddhism has been dominant in Sri Lanka for over 2,000 years, "
                "the island has always had religious diversity. Hindu traditions existed before Buddhism, "
                "and today Sri Lanka has significant Hindu, Muslim, and Christian minorities. "
                "Buddhism arrived in the 3rd century BCE — before that, earlier animist and Hindu "
                "practices were common."
            ),
            "severity": "low"
        }
    }

    def __init__(self):
        print("Anomaly Explanation Engine initialized")

    def detect_misconception(self, query: str) -> Optional[Dict]:
        q = query.lower()
        for key, misconception in self.COMMON_MISCONCEPTIONS.items():
            if any(trigger in q for trigger in misconception["triggers"]):
                return {
                    "misconception_id": key,
                    "correction": misconception["correction"],
                    "severity": misconception["severity"]
                }
        return None

    def check_and_correct(self, query: str, response: str) -> Dict:
        misconception = self.detect_misconception(query)
        if misconception:
            return {
                "anomaly_detected": True,
                "severity": misconception["severity"],
                "corrected_response": (
                    "HISTORICAL CLARIFICATION: " + misconception["correction"]
                    + "\n\nTo also address your question: " + response
                ),
                "original_response": response
            }
        return {"anomaly_detected": False, "response": response}


# =============================================================================
# TEMPORAL COHERENCE ENGINE
# Maintains consistent narratives and facts across multiple sessions
# =============================================================================

class TemporalCoherenceEngine:
    def __init__(self, storage_file: str = "temporal_memory.json"):
        self.storage_file = Path(storage_file)
        self.memory = self._load()
        print("Temporal Coherence Engine initialized")

    def _load(self) -> Dict:
        if self.storage_file.exists():
            try:
                with open(self.storage_file) as f:
                    return json.load(f)
            except Exception:
                pass
        return {}

    def _save(self):
        with open(self.storage_file, "w") as f:
            json.dump(self.memory, f, indent=2)

    def get_user_memory(self, session_id: str) -> Dict:
        if session_id not in self.memory:
            self.memory[session_id] = {
                "created": datetime.now().isoformat(),
                "known_facts": {},
                "character_interactions": {},
                "last_topic": None,
                "narrative_thread": [],
                "established_context": {}
            }
        return self.memory[session_id]

    def record_interaction(self, session_id: str, character_id: str,
                           topic: str, key_fact: str):
        mem = self.get_user_memory(session_id)
        # Record that user knows this fact
        mem["known_facts"][topic] = mem["known_facts"].get(topic, [])
        if key_fact not in mem["known_facts"][topic]:
            mem["known_facts"][topic].append(key_fact)
            if len(mem["known_facts"][topic]) > 10:
                mem["known_facts"][topic] = mem["known_facts"][topic][-10:]
        # Record character interaction
        mem["character_interactions"][character_id] =             mem["character_interactions"].get(character_id, 0) + 1
        mem["last_topic"] = topic
        mem["narrative_thread"].append({
            "topic": topic, "character": character_id,
            "timestamp": datetime.now().isoformat()
        })
        if len(mem["narrative_thread"]) > 30:
            mem["narrative_thread"] = mem["narrative_thread"][-30:]
        self._save()

    def get_context_prefix(self, session_id: str, character_id: str) -> str:
        """Build a context prefix so character remembers previous interactions."""
        mem = self.get_user_memory(session_id)
        count = mem["character_interactions"].get(character_id, 0)
        last = mem["last_topic"]
        if count == 0:
            return ""
        prefix_parts = [f"(You have spoken with this visitor {count} time(s) before."]
        if last:
            prefix_parts.append(f"Your last topic was: {last}.")
        known = list(mem["known_facts"].keys())
        if known:
            prefix_parts.append(f"They already know about: {', '.join(known[:3])}.")
        prefix_parts.append("Build on this knowledge.)")
        return " ".join(prefix_parts)

    def get_full_history(self, session_id: str) -> Dict:
        return self.get_user_memory(session_id)


# =============================================================================
# CRITICAL THINKING PROMPTER
# Challenges user assumptions and encourages deeper historical analysis
# =============================================================================

class CriticalThinkingPrompter:
    PROBING_QUESTIONS = {
        "king": [
            "If you were King Sri Vijaya Rajasinha, how would YOU have balanced Buddhist traditions with the need for military alliances against colonial powers?",
            "The Kandyan kings allied with the Dutch against the Portuguese. Was this a wise strategy, or did it simply trade one colonial threat for another?",
            "King Sri Vijaya Rajasinha was of South Indian Nayak origin, yet ruled Sri Lanka. How does this challenge our assumptions about who can be a 'Sri Lankan' ruler?",
            "If the Sacred Tooth Relic gave legitimacy to rule, what happens to a king's authority if he cannot protect it? Can power rest on a single object?",
        ],
        "nilame": [
            "The Esala Perahera has continued for over 2,000 years across many rulers. What does this tell us about the relationship between religion and political continuity?",
            "If you were the Diyawadana Nilame during colonial rule, how would you preserve sacred traditions under a foreign government that might not respect them?",
            "The Nilame carries enormous responsibility. Is it fair to put the safety of a religion's most sacred object in the hands of one person?",
            "Festivals often blend religion and politics. Can you think of modern examples where religious ceremonies carry political significance, as the Perahera did?",
        ],
        "dutch": [
            "The VOC was one of the world's first multinational corporations. In what ways is it similar to, or different from, modern global companies?",
            "The Dutch argued they 'civilized' Ceylon. How do we evaluate this claim from a modern perspective? Who gets to define civilization?",
            "The VOC's cinnamon monopoly made them incredibly wealthy but also created dependency. What are the long-term consequences of building an economy on a single resource?",
            "If you were a Sri Lankan citizen under Dutch rule, would you cooperate for stability or resist at all costs? What factors would influence your choice?",
        ],
        "citizen": [
            "Sri Lanka has been independent since 1948. In your view, has the country fully decolonized, or do colonial legacies still shape daily life?",
            "History is often told by those who win. How might the story of Sri Lanka's colonial period differ if told entirely from the perspective of ordinary Kandyan villagers?",
            "Cultural heritage can be both a source of pride and a source of tension. Can you think of examples where historical narratives have been used to justify present-day political positions?",
            "If you could change one event in Sri Lankan history, what would it be, and what would be the unintended consequences of that change?",
        ],
        "general": [
            "Whose version of this history are we hearing? What perspectives might be missing?",
            "How might this historical event look completely different through the eyes of the ordinary people — not the kings or commanders?",
            "Are there parallels between this historical event and something happening in the world today?",
            "If this event had gone differently, how might Sri Lanka look today?",
        ]
    }

    def __init__(self):
        self.user_asked = defaultdict(set)
        print("Critical Thinking Prompter initialized")

    def get_challenge_question(self, session_id: str, character_id: str,
                               topic: str) -> Optional[str]:
        import random
        pool = self.PROBING_QUESTIONS.get(character_id, []) + self.PROBING_QUESTIONS["general"]
        # Filter out already-asked questions
        pool = [q for q in pool if q not in self.user_asked[session_id]]
        if not pool:
            # Reset if all asked
            self.user_asked[session_id].clear()
            pool = self.PROBING_QUESTIONS.get(character_id, self.PROBING_QUESTIONS["general"])
        question = random.choice(pool)
        self.user_asked[session_id].add(question)
        return question

    def should_prompt(self, session_id: str, interaction_count: int) -> bool:
        """Prompt every 3 interactions."""
        return interaction_count > 0 and interaction_count % 3 == 0



# =============================================================================
# USER AUTHENTICATION & REGISTRATION MANAGER
# Handles user registration, login, sessions, and secure password hashing
# =============================================================================

class UserAuthManager:
    """
    Manages user registration, authentication, and session tokens.
    Passwords are hashed with SHA-256 + salt. Sessions use secure random tokens.
    """

    def __init__(self, users_file: str = "users.json",
                 sessions_file: str = "auth_sessions.json"):
        self.users_file    = Path(users_file)
        self.sessions_file = Path(sessions_file)
        self._lock         = threading.Lock()
        self.users         = self._load_users()
        self.active_sessions = self._load_sessions()
        print("User Auth Manager initialized")

    # ── persistence ──────────────────────────────────────────────────────────

    def _load_users(self) -> Dict:
        if self.users_file.exists():
            try:
                with open(self.users_file, encoding="utf-8") as f:
                    return json.load(f)
            except Exception:
                pass
        return {}

    def _save_users(self):
        with self._lock:
            with open(self.users_file, "w", encoding="utf-8") as f:
                json.dump(self.users, f, indent=2)

    def _load_sessions(self) -> Dict:
        if self.sessions_file.exists():
            try:
                with open(self.sessions_file, encoding="utf-8") as f:
                    return json.load(f)
            except Exception:
                pass
        return {}

    def _save_sessions(self):
        with self._lock:
            with open(self.sessions_file, "w", encoding="utf-8") as f:
                json.dump(self.active_sessions, f, indent=2)

    # ── helpers ───────────────────────────────────────────────────────────────

    def _hash_password(self, password: str, salt: str) -> str:
        return hashlib.sha256((salt + password).encode("utf-8")).hexdigest()

    def _validate_email(self, email: str) -> bool:
        return bool(_re.match(r"^[^@\s]+@[^@\s]+\.[^@\s]+$", email))

    def _validate_password(self, password: str) -> Tuple[bool, str]:
        if len(password) < 6:
            return False, "Password must be at least 6 characters"
        return True, "OK"

    def _generate_token(self) -> str:
        return secrets.token_hex(32)

    # ── public API ────────────────────────────────────────────────────────────

    def register(self, username: str, email: str, password: str,
                 full_name: str = "", age_group: str = "adult",
                 expertise_level: str = "tourist") -> Dict:
        """Register a new user. Returns success/error dict."""
        username = username.strip().lower()
        email    = email.strip().lower()

        # Validation
        if not username or len(username) < 3:
            return {"success": False, "error": "Username must be at least 3 characters"}
        if not _re.match(r"^[a-z0-9_]+$", username):
            return {"success": False, "error": "Username: only letters, numbers, underscores"}
        if username in self.users:
            return {"success": False, "error": f"Username '{username}' already taken"}
        if not self._validate_email(email):
            return {"success": False, "error": "Invalid email address"}
        # Check email uniqueness
        if any(u["email"] == email for u in self.users.values()):
            return {"success": False, "error": "Email already registered"}
        ok, msg = self._validate_password(password)
        if not ok:
            return {"success": False, "error": msg}
        if expertise_level not in ["child", "student", "researcher", "tourist"]:
            expertise_level = "tourist"

        # Create user record
        salt = secrets.token_hex(16)
        user_id = str(uuid.uuid4())
        self.users[username] = {
            "user_id":        user_id,
            "username":       username,
            "email":          email,
            "full_name":      full_name.strip(),
            "password_hash":  self._hash_password(password, salt),
            "salt":           salt,
            "age_group":      age_group,
            "expertise_level": expertise_level,
            "created_at":     datetime.now().isoformat(),
            "last_login":     None,
            "total_sessions": 0,
            "is_active":      True,
            "preferences": {
                "favorite_character": "king",
                "language":           "en",
                "notifications":      True
            }
        }
        self._save_users()
        return {
            "success":  True,
            "user_id":  user_id,
            "username": username,
            "message":  f"Welcome, {full_name or username}! Registration successful."
        }

    def login(self, username: str, password: str) -> Dict:
        """Authenticate user and return a session token."""
        username = username.strip().lower()
        user = self.users.get(username)
        if not user:
            return {"success": False, "error": "Invalid username or password"}
        if not user.get("is_active", True):
            return {"success": False, "error": "Account deactivated"}
        hashed = self._hash_password(password, user["salt"])
        if hashed != user["password_hash"]:
            return {"success": False, "error": "Invalid username or password"}

        # Generate session token
        token = self._generate_token()
        self.active_sessions[token] = {
            "username":   username,
            "user_id":    user["user_id"],
            "created_at": datetime.now().isoformat(),
            "expires_at": None,   # no expiry for simplicity; add TTL if needed
        }
        # Update last login
        user["last_login"]     = datetime.now().isoformat()
        user["total_sessions"] = user.get("total_sessions", 0) + 1
        self._save_users()
        self._save_sessions()

        return {
            "success":        True,
            "token":          token,
            "user_id":        user["user_id"],
            "username":       username,
            "full_name":      user.get("full_name", ""),
            "expertise_level": user.get("expertise_level", "tourist"),
            "message":        f"Welcome back, {user.get('full_name') or username}!"
        }

    def logout(self, token: str) -> Dict:
        if token in self.active_sessions:
            del self.active_sessions[token]
            self._save_sessions()
            return {"success": True, "message": "Logged out successfully"}
        return {"success": False, "error": "Invalid or expired token"}

    def verify_token(self, token: str) -> Optional[Dict]:
        """Return session info if token is valid, else None."""
        session = self.active_sessions.get(token)
        if not session:
            return None
        username = session["username"]
        user = self.users.get(username)
        if not user or not user.get("is_active", True):
            return None
        return {"username": username, "user_id": session["user_id"],
                "session": session, "user": user}

    def get_user_profile(self, username: str) -> Optional[Dict]:
        user = self.users.get(username)
        if not user:
            return None
        # Return without sensitive fields
        safe = {k: v for k, v in user.items()
                if k not in ["password_hash", "salt"]}
        return safe

    def update_profile(self, username: str, updates: Dict) -> Dict:
        user = self.users.get(username)
        if not user:
            return {"success": False, "error": "User not found"}
        allowed = ["full_name", "age_group", "expertise_level", "preferences"]
        for key in allowed:
            if key in updates:
                if key == "expertise_level" and updates[key] not in [
                        "child", "student", "researcher", "tourist"]:
                    continue
                user[key] = updates[key]
        self._save_users()
        return {"success": True, "message": "Profile updated"}

    def change_password(self, username: str, old_password: str,
                        new_password: str) -> Dict:
        user = self.users.get(username)
        if not user:
            return {"success": False, "error": "User not found"}
        hashed = self._hash_password(old_password, user["salt"])
        if hashed != user["password_hash"]:
            return {"success": False, "error": "Current password incorrect"}
        ok, msg = self._validate_password(new_password)
        if not ok:
            return {"success": False, "error": msg}
        user["salt"]          = secrets.token_hex(16)
        user["password_hash"] = self._hash_password(new_password, user["salt"])
        self._save_users()
        return {"success": True, "message": "Password changed successfully"}

    def list_users(self) -> List[Dict]:
        """Admin: list all users (without sensitive fields)."""
        return [
            {k: v for k, v in u.items() if k not in ["password_hash", "salt"]}
            for u in self.users.values()
        ]

    def delete_user(self, username: str) -> Dict:
        if username not in self.users:
            return {"success": False, "error": "User not found"}
        # Revoke all sessions
        to_delete = [t for t, s in self.active_sessions.items()
                     if s["username"] == username]
        for t in to_delete:
            del self.active_sessions[t]
        del self.users[username]
        self._save_users()
        self._save_sessions()
        return {"success": True, "message": f"User '{username}' deleted"}

    def get_stats(self) -> Dict:
        return {
            "total_users":          len(self.users),
            "active_sessions":      len(self.active_sessions),
            "active_users":         sum(1 for u in self.users.values() if u.get("is_active")),
            "users_by_expertise":   {
                level: sum(1 for u in self.users.values()
                           if u.get("expertise_level") == level)
                for level in ["child", "student", "researcher", "tourist"]
            }
        }


# =============================================================================
# CHAT HISTORY MANAGER
# Stores and retrieves full conversation history per user and session
# =============================================================================

class ChatHistoryManager:
    """
    Stores every chat message (question + answer) per user, per session.
    Supports filtering by character, topic, date range, and full-text search.
    """

    def __init__(self, history_file: str = "chat_history.json",
                 max_per_user: int = 500):
        self.history_file = Path(history_file)
        self.max_per_user = max_per_user
        self._lock        = threading.Lock()
        self.history      = self._load()
        print("Chat History Manager initialized")

    def _load(self) -> Dict:
        if self.history_file.exists():
            try:
                with open(self.history_file, encoding="utf-8") as f:
                    return json.load(f)
            except Exception:
                pass
        return {}

    def _save(self):
        with self._lock:
            with open(self.history_file, "w", encoding="utf-8") as f:
                json.dump(self.history, f, indent=2)

    def _user_key(self, username: str) -> str:
        return username.strip().lower()

    def add_message(self, username: str, session_id: str, character_id: str,
                    question: str, answer: str, topic: str = "general",
                    intent: str = "general", confidence: float = 0.9,
                    extra: Dict = None) -> str:
        """Store a chat exchange. Returns the message_id."""
        key = self._user_key(username)
        if key not in self.history:
            self.history[key] = []

        msg_id = str(uuid.uuid4())
        entry = {
            "msg_id":       msg_id,
            "session_id":   session_id,
            "character_id": character_id,
            "character_name": CHARACTERS.get(character_id, {}).get("name", character_id),
            "question":     question,
            "answer":       answer,
            "topic":        topic,
            "intent":       intent,
            "confidence":   round(confidence, 4),
            "timestamp":    datetime.now().isoformat(),
            "extra":        extra or {}
        }
        self.history[key].append(entry)

        # Trim to max
        if len(self.history[key]) > self.max_per_user:
            self.history[key] = self.history[key][-self.max_per_user:]

        self._save()
        return msg_id

    def get_history(self, username: str,
                    session_id: str = None,
                    character_id: str = None,
                    topic: str = None,
                    search: str = None,
                    limit: int = 50,
                    offset: int = 0,
                    date_from: str = None,
                    date_to: str = None) -> Dict:
        """Return filtered chat history for a user."""
        key = self._user_key(username)
        records = self.history.get(key, [])

        # Apply filters
        if session_id:
            records = [r for r in records if r["session_id"] == session_id]
        if character_id:
            records = [r for r in records if r["character_id"] == character_id]
        if topic:
            records = [r for r in records if r["topic"] == topic]
        if date_from:
            records = [r for r in records if r["timestamp"] >= date_from]
        if date_to:
            records = [r for r in records if r["timestamp"] <= date_to]
        if search:
            s = search.lower()
            records = [r for r in records
                       if s in r["question"].lower() or s in r["answer"].lower()]

        total = len(records)
        # Most recent first
        records = list(reversed(records))
        page = records[offset: offset + limit]

        return {
            "total":    total,
            "limit":    limit,
            "offset":   offset,
            "returned": len(page),
            "records":  page
        }

    def get_session_list(self, username: str) -> List[Dict]:
        """Return a summary list of all unique sessions for the user."""
        key = self._user_key(username)
        records = self.history.get(key, [])
        sessions = {}
        for r in records:
            sid = r["session_id"]
            if sid not in sessions:
                sessions[sid] = {
                    "session_id":   sid,
                    "first_message": r["timestamp"],
                    "last_message":  r["timestamp"],
                    "message_count": 0,
                    "characters_used": set(),
                    "topics": set()
                }
            s = sessions[sid]
            s["last_message"]  = r["timestamp"]
            s["message_count"] += 1
            s["characters_used"].add(r["character_id"])
            s["topics"].add(r["topic"])
        # Convert sets to lists
        result = []
        for s in sessions.values():
            s["characters_used"] = list(s["characters_used"])
            s["topics"]          = list(s["topics"])
            result.append(s)
        result.sort(key=lambda x: x["last_message"], reverse=True)
        return result

    def get_stats(self, username: str) -> Dict:
        key = self._user_key(username)
        records = self.history.get(key, [])
        if not records:
            return {"total_messages": 0, "sessions": 0, "characters": {},
                    "topics": {}, "avg_confidence": 0}
        char_count  = defaultdict(int)
        topic_count = defaultdict(int)
        confs       = []
        sessions    = set()
        for r in records:
            char_count[r["character_id"]]  += 1
            topic_count[r["topic"]]        += 1
            sessions.add(r["session_id"])
            if r.get("confidence"):
                confs.append(r["confidence"])
        return {
            "total_messages":  len(records),
            "sessions":        len(sessions),
            "characters":      dict(char_count),
            "topics":          dict(topic_count),
            "avg_confidence":  round(float(np.mean(confs)), 4) if confs else 0,
            "first_message":   records[0]["timestamp"] if records else None,
            "last_message":    records[-1]["timestamp"] if records else None,
        }

    def delete_session(self, username: str, session_id: str) -> Dict:
        key = self._user_key(username)
        before = len(self.history.get(key, []))
        self.history[key] = [r for r in self.history.get(key, [])
                              if r["session_id"] != session_id]
        deleted = before - len(self.history[key])
        self._save()
        return {"success": True, "deleted_messages": deleted}

    def delete_all(self, username: str) -> Dict:
        key = self._user_key(username)
        count = len(self.history.get(key, []))
        self.history[key] = []
        self._save()
        return {"success": True, "deleted_messages": count}

    def export_history(self, username: str,
                       session_id: str = None) -> List[Dict]:
        """Export full history (for download)."""
        result = self.get_history(username, session_id=session_id, limit=10000)
        return result["records"]


# =============================================================================
# TRAINING CALLBACK
# =============================================================================

class CustomTrainingCallback(TrainerCallback):
    def __init__(self, tracker: MetricsTracker):
        self.tracker = tracker

    def on_log(self, args, state, control, logs=None, **kwargs):
        if logs and state.global_step and "loss" in logs:
            self.tracker.log_training_metric(
                state.global_step, logs["loss"],
                state.epoch if state.epoch else 0
            )

# =============================================================================
# MAIN CHATBOT
# =============================================================================

class MultiCharacterChatbot:
    def __init__(self, config: Dict, data_loader: DataLoader):
        self.config = config
        self.data_loader = data_loader
        self.characters = CHARACTERS
        self.model = None
        self.tokenizer = None
        self.vector_db = None
        self.rl = RLRecommender(config)
        self.profiles = UserProfileManager(config["profiles_file"])
        self.intents = IntentClassifier()
        self.metrics = MetricsTracker(config["metrics_file"])
        self.sessions: Dict[str, Dict] = {}
        self.hf_uploader = HFUploader(config["adapter_repo"], config["local_adapter_path"])
        # New VR/AI feature engines
        self.quiz_engine       = VRQuizEngine()
        self.predictor         = PredictiveTopicEngine()
        self.expertise_adapter = UserExpertiseAdapter()
        self.sensitivity       = CulturalSensitivityEngine()
        self.folklore          = LegendFolkloreEngine()
        self.causal_chain      = CausalChainEngine()
        self.vr_discovery      = VRContentDiscoveryEngine()
        self.anomaly_engine    = AnomalyExplanationEngine()
        self.temporal_memory   = TemporalCoherenceEngine()
        self.critical_prompter = CriticalThinkingPrompter()
        self.interaction_count = defaultdict(int)
        # Auth + History (initialized in main, set here after construction)
        self.auth: Optional["UserAuthManager"] = None
        self.history_mgr: Optional["ChatHistoryManager"] = None
        print("MultiCharacterChatbot initialized with all VR/AI engines")

    # ── Model loading ─────────────────────────────────────────────────────────

    def _load_model(self) -> bool:
        """
        Load TinyLlama (no token needed).
        Then attach adapter in priority order:
          1. Local ./lora_adapter/ (if fine-tuned)
          2. Public HF repo (no token needed)
          3. Base model only (if neither exists)
        """
        print(f"\nLoading base model: {self.config['base_model']}")
        for attempt in range(self.config["max_retries"]):
            try:
                self.tokenizer = AutoTokenizer.from_pretrained(
                    self.config["base_model"],
                    trust_remote_code=True,
                    cache_dir="./model_cache"
                )
                if self.tokenizer.pad_token is None:
                    self.tokenizer.pad_token = self.tokenizer.eos_token

                base = AutoModelForCausalLM.from_pretrained(
                    self.config["base_model"],
                    dtype=torch.float16 if torch.cuda.is_available() else torch.float32,
                    low_cpu_mem_usage=True, trust_remote_code=True,
                    device_map="auto", cache_dir="./model_cache"
                )
                print("Base model loaded")

                # Priority 1: local adapter
                local = Path(self.config["local_adapter_path"])
                if local.exists() and any(local.iterdir()):
                    try:
                        self.model = PeftModel.from_pretrained(base, str(local))
                        print(f"Local adapter loaded from {local}")
                    except Exception as e:
                        print(f"Local adapter failed ({e}) - trying public HF")
                        self.model = HFUploader.load_public_adapter(
                            base, self.config["adapter_repo"]
                        )
                else:
                    # Priority 2: public HF repo (no token)
                    self.model = HFUploader.load_public_adapter(
                        base, self.config["adapter_repo"]
                    )

                self.model.eval()
                return True

            except Exception as e:
                print(f"Attempt {attempt+1}/{self.config['max_retries']}: {str(e)[:120]}")
                if attempt < self.config["max_retries"] - 1:
                    time.sleep((attempt + 1) * 30)
        print("All retries exhausted")
        return False

    def setup(self):
        """Load model + build knowledge base"""
        ok = self._load_model()
        if not ok:
            raise RuntimeError("Model loading failed.")
        self._build_knowledge_base()

    def _build_knowledge_base(self):
        print("\nBuilding knowledge base...")
        self.vector_db = VectorDatabase(
            self.config["embedding_model"],
            max_retries=self.config["max_retries"]
        )
        texts, metas = [], []
        for item in self.data_loader.data:
            text = f"Question: {item['question']}\nAnswer: {item['answer']}"
            if item.get("context"):
                text += f"\nContext: {item['context']}"
            texts.append(text)
            metas.append({"character": item.get("character", "all"),
                           "question": item["question"]})
        self.vector_db.add_documents(texts, metas)
        print(f"Knowledge base ready ({len(texts)} entries)")

    # ── Fine-tuning ───────────────────────────────────────────────────────────

    def fine_tune(self) -> bool:
        """Fine-tune TinyLlama with LoRA, save adapter to local_adapter_path."""
        if self.model is None:
            if not self._load_model():
                raise RuntimeError("Cannot fine-tune: model not loaded")

        print("\n" + "="*60)
        print("FINE-TUNING WITH LORA (TinyLlama 1.1B)")
        print("="*60)

        train_texts = self.data_loader.prepare_for_training()
        print(f"{len(train_texts)} training examples")

        tokenized = self.tokenizer(
            train_texts, truncation=True, padding="max_length",
            max_length=self.config["max_length"], return_tensors="pt"
        )
        dataset = Dataset.from_dict({
            "input_ids": tokenized["input_ids"],
            "attention_mask": tokenized["attention_mask"]
        })

        lora_cfg = LoraConfig(
            r=self.config["lora_r"], lora_alpha=self.config["lora_alpha"],
            lora_dropout=self.config["lora_dropout"],
            target_modules=["q_proj", "v_proj", "k_proj", "o_proj"],
            task_type=TaskType.CAUSAL_LM, bias="none"
        )

        base = self.model.base_model if isinstance(self.model, PeftModel) else self.model
        peft_model = get_peft_model(base, lora_cfg)
        peft_model.print_trainable_parameters()

        os.makedirs("./lora_output", exist_ok=True)
        training_args = TrainingArguments(
            output_dir="./lora_output",
            num_train_epochs=self.config["num_train_epochs"],
            per_device_train_batch_size=self.config["per_device_train_batch_size"],
            gradient_accumulation_steps=self.config["gradient_accumulation_steps"],
            learning_rate=self.config["learning_rate"],
            warmup_steps=self.config["warmup_steps"],
            logging_steps=self.config["logging_steps"],
            save_steps=self.config["save_steps"],
            save_strategy="steps", save_total_limit=2,
            report_to="none", remove_unused_columns=False,
        )

        trainer = Trainer(
            model=peft_model, args=training_args, train_dataset=dataset,
            data_collator=DataCollatorForLanguageModeling(
                tokenizer=self.tokenizer, mlm=False
            ),
            callbacks=[CustomTrainingCallback(self.metrics)]
        )

        print("Training started...")
        trainer.train()

        adapter_path = self.config["local_adapter_path"]
        os.makedirs(adapter_path, exist_ok=True)
        peft_model.save_pretrained(adapter_path)
        self.tokenizer.save_pretrained(adapter_path)
        print(f"Adapter saved to {adapter_path}")

        self.model = peft_model
        self.model.eval()
        self._build_knowledge_base()
        return True

    def upload_to_hf(self, hf_write_token: str) -> bool:
        """Upload local adapter to PUBLIC HF repo (no token needed to download after)."""
        return self.hf_uploader.upload(hf_write_token)

    # ── Session ───────────────────────────────────────────────────────────────

    def _session(self, session_id: str, char_id: str) -> Dict:
        key = f"{session_id}_{char_id}"
        if key not in self.sessions:
            self.sessions[key] = {
                "history": deque(maxlen=self.config["memory_size"]),
                "greeted": False
            }
        return self.sessions[key]

    def _exact_match(self, query: str, char_id: str) -> Optional[str]:
        q = query.lower().strip()
        for item in self.data_loader.data:
            if item.get("character") not in [char_id, "all"]:
                continue
            iq = item["question"].lower().strip()
            if q == iq:
                return item["answer"]
            qw, iqw = set(q.split()), set(iq.split())
            if len(qw) > 2 and len(qw & iqw) / len(qw) > 0.8:
                return item["answer"]
        return None

    def _chatml_prompt(self, char: Dict, context: str, query: str) -> str:
        system = (
            f"You are {char['name']}, {char['title']}. "
            f"{char['personality']}. Speaking style: {char['speaking_style']}. "
            f"Expertise: {', '.join(char['expertise'])}. "
            "Use only the provided historical knowledge to answer."
        )
        return (
            f"<|system|>\n{system}</s>\n"
            f"<|user|>\nHistorical Knowledge:\n{context}\n\nQuestion: {query}</s>\n"
            "<|assistant|>\n"
        )

    def _generate(self, prompt: str) -> str:
        inputs = self.tokenizer(
            prompt, return_tensors="pt",
            truncation=True, max_length=self.config["max_length"]
        )
        if torch.cuda.is_available():
            inputs = {k: v.to(self.model.device) for k, v in inputs.items()}
        with torch.no_grad():
            out = self.model.generate(
                **inputs,
                max_new_tokens=self.config["max_new_tokens"],
                temperature=self.config["temperature"],
                top_p=self.config["top_p"],
                repetition_penalty=self.config["repetition_penalty"],
                do_sample=True,
                pad_token_id=self.tokenizer.pad_token_id,
                eos_token_id=self.tokenizer.eos_token_id
            )
        decoded = self.tokenizer.decode(out[0], skip_special_tokens=True)
        if "<|assistant|>" in decoded:
            return decoded.split("<|assistant|>")[-1].strip().split("\n\n")[0].strip()
        if "### Response:" in decoded:
            return decoded.split("### Response:")[-1].strip().split("\n\n")[0].strip()
        return decoded[len(prompt):].strip().split("\n\n")[0].strip()

    # ── Main answer generation ────────────────────────────────────────────────

    def _chatml_prompt_enhanced(self, char: Dict, context: str, query: str,
                                 session_id: str = "default") -> str:
        """Build prompt with expertise adaptation, sensitivity, and temporal memory."""
        base_system = (
            f"You are {char['name']}, {char['title']}. "
            f"{char['personality']}. Speaking style: {char['speaking_style']}. "
            f"Expertise: {', '.join(char['expertise'])}. "
            "Use only the provided historical knowledge to answer."
        )
        # Apply expertise adaptation
        system = self.expertise_adapter.adapt_system_prompt(base_system, session_id)
        # Apply cultural sensitivity
        system = self.sensitivity.apply_to_prompt(system, query)
        # Apply temporal memory context
        mem_prefix = self.temporal_memory.get_context_prefix(session_id, char["id"])
        if mem_prefix:
            system = system + " " + mem_prefix
        return (
            f"<|system|>\n{system}</s>\n"
            f"<|user|>\nHistorical Knowledge:\n{context}\n\nQuestion: {query}</s>\n"
            "<|assistant|>\n"
        )

    def generate_answer(self, query: str, char_id: str,
                        session_id: str = "default",
                        expertise_level: str = None) -> Dict:
        if char_id not in self.characters:
            return {"answer": f"Unknown character. Options: {', '.join(self.characters.keys())}",
                    "error": True, "character": "System", "title": "Error"}
        if self.model is None:
            return {"answer": "Model not loaded.", "error": True,
                    "character": "System", "title": "Error"}

        t0 = time.time()
        char = self.characters[char_id]
        sess = self._session(session_id, char_id)
        intent = self.intents.classify(query)
        topic = self.intents.extract_topic(query)

        # Set expertise level if provided
        if expertise_level:
            self.expertise_adapter.set_user_level(session_id, expertise_level)

        self.metrics.log_intent(intent)
        self.metrics.log_topic(topic)
        self.metrics.log_character(char_id)
        self.interaction_count[session_id] += 1
        self.predictor.record_topic_visit(session_id, topic)

        # Check for anomaly/misconception first
        anomaly_check = self.anomaly_engine.detect_misconception(query)

        # Greeting
        if intent == "greeting" and not sess["greeted"]:
            sess["greeted"] = True
            elapsed = time.time() - t0
            self.metrics.log_query_time(query, char_id, elapsed)
            greeting_answer = char["greeting"]
            # Add expertise-aware greeting suffix
            level = self.expertise_adapter.get_user_level(session_id)
            if level == "child":
                greeting_answer += " Ask me anything — I love teaching young minds!"
            elif level == "researcher":
                greeting_answer += " I welcome scholarly inquiry."
            return {"answer": greeting_answer, "character": char["name"],
                    "title": char["title"], "intent": intent, "topic": topic,
                    "confidence": 0.99, "sources": [], "recommendations": [],
                    "retrieval_time": 0.0, "total_time": time.time() - t0,
                    "vr_sites": [], "predicted_topics": [], "critical_question": None,
                    "folklore": None, "causal_chain": None, "anomaly": None}

        # Exact match
        exact = self._exact_match(query, char_id)
        if exact:
            answer = exact
            # Enrich with folklore if relevant
            folklore_result = self.folklore.enrich_response(answer, query)
            # Check causal chain
            chain = self.causal_chain.find_chain(query)
            elapsed = time.time() - t0
            self.metrics.log_query_time(query, char_id, elapsed)
            sess["history"].append({"query": query, "answer": answer})
            self.profiles.update_profile(session_id, char_id, query, topic)
            self.temporal_memory.record_interaction(session_id, char_id, topic, query[:80])
            vr_sites = self.vr_discovery.suggest_sites(session_id, topic, char_id, top_n=2)
            predicted = self.predictor.predict_next_topics(
                session_id, topic, char_id,
                [h["query"] for h in list(sess["history"])[-5:]] if sess["history"] else [],
                top_n=3
)
            critical_q = None
            if self.critical_prompter.should_prompt(session_id, self.interaction_count[session_id]):
                critical_q = self.critical_prompter.get_challenge_question(session_id, char_id, topic)
            return {
                "answer": answer, "character": char["name"], "title": char["title"],
                "intent": intent, "topic": topic, "confidence": 0.97,
                "sources": [{"text": "Knowledge base direct match", "similarity": 0.97}],
                "recommendations": [], "retrieval_time": 0.0, "total_time": elapsed,
                "vr_sites": vr_sites, "predicted_topics": predicted,
                "critical_question": critical_q,
                "folklore": folklore_result if folklore_result["enriched"] else None,
                "causal_chain": self.causal_chain.format_chain(chain) if chain else None,
                "anomaly": {"detected": True, "correction": anomaly_check["correction"]} if anomaly_check else None,
                "expertise_level": self.expertise_adapter.get_user_level(session_id),
                "sensitivity_flags": [d["sensitivity_type"] for d in self.sensitivity.analyze(query)["detected_sensitivities"]]
            }

        # RAG
        retrieved, rt = self.vector_db.retrieve(
            query, char_id, self.config["top_k_retrieval"]
        )
        filtered = [d for d in retrieved
                    if d["similarity"] >= self.config["similarity_threshold"]]
        self.metrics.log_rag_performance(
            query, rt, [d["similarity"] for d in retrieved], len(filtered)
        )

        # ── Define chain BEFORE the if/else so it's always available ──
        chain = self.causal_chain.find_chain(query)

        if not filtered:
            answer = (
                f"I apologize, but I don't have specific information on that "
                f"from my perspective as {char['title']}. "
                f"Please ask about {', '.join(char['expertise'][:2])}."
            )
            confidence = 0.5
        else:
            best_sim = filtered[0]["similarity"]
            context = "\n\n".join(d["text"] for d in filtered[:3])
            if chain:
                context = self.causal_chain.format_chain(chain) + "\n\n" + context

            if best_sim > 0.80:
                answer = filtered[0]["text"].split("Answer:")[-1].strip()
                confidence = best_sim
            else:
                # Use enhanced prompt with all adaptations
                prompt = self._chatml_prompt_enhanced(char, context, query, session_id)
                try:
                    answer = self._generate(prompt)
                    if len(answer) < 25:
                        answer = filtered[0]["text"].split("Answer:")[-1].strip()
                    confidence = best_sim
                except Exception as e:
                    print(f"Generation error: {e}")
                    answer = filtered[0]["text"].split("Answer:")[-1].strip()
                    confidence = best_sim

        # If anomaly detected, prepend correction
        if anomaly_check:
            answer = f"HISTORICAL CLARIFICATION: {anomaly_check['correction']}\n\n{answer}"

        # Enrich with folklore
        folklore_result = self.folklore.enrich_response(answer, query)

        available = list({d["metadata"].get("question", "") for d in retrieved
                          if d["metadata"].get("question")})
        recs = self.rl.recommend_topics(session_id, char_id, topic, available, top_n=3)

        elapsed = time.time() - t0
        self.metrics.log_query_time(query, char_id, elapsed)
        sess["history"].append({"query": query, "answer": answer})
        self.profiles.update_profile(session_id, char_id, query, topic)
        self.temporal_memory.record_interaction(session_id, char_id, topic, query[:80])
        confidence = max(0.80, min(0.99, float(confidence)))

        # Build enrichments
        vr_sites = self.vr_discovery.suggest_sites(session_id, topic, char_id, top_n=2)
        predicted = self.predictor.predict_next_topics(
            session_id, topic, char_id,
            [h["query"] for h in list(sess["history"])[-5:]], top_n=3
        )
        critical_q = None
        if self.critical_prompter.should_prompt(session_id, self.interaction_count[session_id]):
            critical_q = self.critical_prompter.get_challenge_question(session_id, char_id, topic)

        result = {
            "answer": answer,
            "character": char["name"], "title": char["title"],
            "intent": intent, "topic": topic, "confidence": confidence,
            "sources": [{"text": d["text"][:100] + "...",
                         "similarity": float(d["similarity"])}
                        for d in filtered[:2]],
            "recommendations": recs,
            "retrieval_time": rt, "total_time": elapsed,
            # NEW enrichment fields
            "vr_sites":         vr_sites,
            "predicted_topics": predicted,
            "critical_question": critical_q,
            "folklore": folklore_result if folklore_result["enriched"] else None,
            "causal_chain": self.causal_chain.format_chain(chain) if chain else None,
            "anomaly": {"detected": True, "correction": anomaly_check["correction"]} if anomaly_check else None,
            "expertise_level": self.expertise_adapter.get_user_level(session_id),
            "sensitivity_flags": self.sensitivity.analyze(query)["detected_sensitivities"]
        }
        # Auto-save to chat history if manager is available
        if self.history_mgr:
            try:
                # Use real username from auth if available, else session_id
                save_username = session_id
                if self.auth:
                    for _tok, _sess in self.auth.active_sessions.items():
                        if _sess.get("username") and _sess["username"] in self.auth.users:
                            if session_id == _sess["username"]:
                                save_username = _sess["username"]
                                break
                self.history_mgr.add_message(
                    username=save_username,
                    session_id=session_id,
                    character_id=char_id,
                    question=query,
                    answer=answer,
                    topic=topic,
                    intent=intent,
                    confidence=confidence
                )
            except Exception as _he:
                print(f"[history warn] {_he}")
        return result

    def provide_feedback(self, session_id: str, char_id: str,
                         query: str, rating: float) -> Dict:
        topic = self.intents.extract_topic(query)
        self.rl.record_feedback(session_id, char_id, topic, rating)
        self.profiles.update_profile(session_id, char_id, query, topic, rating)
        reward = (rating - 3) / 2
        self.metrics.log_user_rating(session_id, char_id, rating, topic)
        self.metrics.log_rl_reward(session_id, char_id, topic, reward)
        sess = self._session(session_id, char_id)
        history = [h["query"] for h in list(sess["history"])[-5:]]
        if len(history) > 1:
            state = self.rl.get_state(session_id, char_id, topic, history[:-1])
            nstate = self.rl.get_state(session_id, char_id, topic, history)
            self.rl.update_q_value(
                state, topic, reward, nstate,
                list(self.rl.q_table[nstate].keys())
            )
        return {"success": True, "reward": reward,
                "epsilon": self.rl.epsilon, "message": "Feedback recorded"}

# =============================================================================
# VISUALIZATIONS
# =============================================================================

def _empty_fig(title: str, msg: str):
    fig = go.Figure()
    fig.add_annotation(text=msg, xref="paper", yref="paper",
                       x=0.5, y=0.5, showarrow=False, font=dict(size=14))
    fig.update_layout(height=500, title=title)
    return fig

def create_training_viz(metrics: MetricsTracker):
    data = metrics.metrics.get("training_metrics", [])
    if not data:
        return _empty_fig("Training Loss", "No data yet - run fine-tuning first")
    df = pd.DataFrame(data)
    fig = go.Figure()
    fig.add_trace(go.Scatter(x=df["step"], y=df["loss"], mode="lines+markers",
                             name="Loss", line=dict(color="#FF6B6B", width=2)))
    fig.update_layout(title="Training Loss Over Time", xaxis_title="Step",
                      yaxis_title="Loss", height=500, template="plotly_white")
    return fig

def create_rag_viz(metrics: MetricsTracker):
    data = metrics.metrics["rag_performance"]
    if not data:
        return _empty_fig("RAG Performance", "No data yet - start chatting!")
    df = pd.DataFrame(data)
    fig = make_subplots(rows=2, cols=2,
                        subplot_titles=("Avg Similarity", "Retrieval Time (s)",
                                        "Docs Retrieved", "Score Distribution"))
    fig.add_trace(go.Scatter(x=list(range(len(df))), y=df["avg_similarity"],
                             mode="lines+markers",
                             line=dict(color="#4ECDC4")), row=1, col=1)
    fig.add_trace(go.Histogram(x=df["retrieval_time"],
                               marker_color="#95E1D3"), row=1, col=2)
    fig.add_trace(go.Scatter(x=list(range(len(df))), y=df["num_docs"],
                             mode="lines+markers",
                             line=dict(color="#F38181")), row=2, col=1)
    if metrics.metrics["retrieval_scores"]:
        fig.add_trace(go.Histogram(x=metrics.metrics["retrieval_scores"],
                                   marker_color="#AA96DA"), row=2, col=2)
    fig.update_layout(height=800, showlegend=False, title_text="RAG Performance")
    return fig

def create_rl_viz(metrics: MetricsTracker, rl: RLRecommender):
    rewards = metrics.metrics["rl_rewards"]
    ratings = metrics.metrics["user_ratings"]
    if not rewards and not ratings:
        return _empty_fig("RL Performance", "No data yet - submit feedback!")
    fig = make_subplots(rows=2, cols=2,
                        subplot_titles=("Rewards Over Time", "Rating Distribution",
                                        "Avg Rating by Character", "Q-Table Stats"),
                        specs=[[{"type": "scatter"}, {"type": "bar"}],
                               [{"type": "bar"}, {"type": "table"}]])
    if rewards:
        fig.add_trace(go.Scatter(x=list(range(len(rewards))),
                                 y=[r["reward"] for r in rewards],
                                 mode="lines+markers",
                                 line=dict(color="#6C5CE7")), row=1, col=1)
    if ratings:
        df_r = pd.DataFrame(ratings)
        fig.add_trace(go.Histogram(x=df_r["rating"],
                                   marker_color="#A29BFE"), row=1, col=2)
        avg = df_r.groupby("character")["rating"].mean().sort_values(ascending=False)
        fig.add_trace(go.Bar(x=avg.index, y=avg.values,
                             marker_color="#FD79A8"), row=2, col=1)
    q = rl.get_q_table_stats()
    fig.add_trace(go.Table(
        header=dict(values=["Metric", "Value"],
                    fill_color="#74B9FF", align="left"),
        cells=dict(values=[
            ["States", "Actions", "Avg Q", "Max Q", "Min Q"],
            [q["num_states"], q["num_actions"],
             f"{q['avg_q_value']:.4f}", f"{q['max_q_value']:.4f}",
             f"{q['min_q_value']:.4f}"]
        ], fill_color="#DFE6E9", align="left")
    ), row=2, col=2)
    fig.update_layout(height=800, showlegend=False, title_text="RL Performance")
    return fig

def create_analytics_viz(metrics: MetricsTracker):
    id_dist = metrics.metrics["intent_distribution"]
    ch_dist = metrics.metrics["character_distribution"]
    if not id_dist and not ch_dist:
        return _empty_fig("Analytics", "No data yet - start chatting!")
    fig = make_subplots(rows=1, cols=2,
                        subplot_titles=("Intent Distribution", "Character Usage"),
                        specs=[[{"type": "pie"}, {"type": "pie"}]])
    if id_dist:
        fig.add_trace(go.Pie(labels=list(id_dist.keys()),
                             values=list(id_dist.values())), row=1, col=1)
    if ch_dist:
        fig.add_trace(go.Pie(labels=list(ch_dist.keys()),
                             values=list(ch_dist.values())), row=1, col=2)
    fig.update_layout(height=400, title_text="User Analytics")
    return fig

# =============================================================================
# GRADIO UI
# =============================================================================

def create_gradio_ui(chatbot: MultiCharacterChatbot):
    """
    Complete Gradio UI with all tabs — version-safe for Gradio 3.x and 4.x.
    """
    current = {"char_id": "king"}
    current_token = {"value": ""}   # report tab reads this after login

    # ── Detect Gradio version → pick correct chatbot history format ───────────
    import gradio as _gr_check
    _gr_ver = tuple(int(x) for x in _gr_check.__version__.split(".")[:2])
    _MSGS_FMT = _gr_ver >= (4, 0)   # True = dicts, False = tuples

    def _make_history(history, user_msg, bot_msg):
        """Append a turn in the format this Gradio version expects."""
        h = history or []
        if _MSGS_FMT:
            return h + [{"role": "user", "content": user_msg},
                        {"role": "assistant", "content": bot_msg}]
        return h + [(user_msg, bot_msg)]

    def _make_chatbot():
        """Create gr.Chatbot, handling the type= arg only on Gradio 4.x."""
        if _MSGS_FMT:
            try:
                return gr.Chatbot(value=[], height=450, label="Conversation",
                                  type="messages")
            except TypeError:
                pass
        return gr.Chatbot(value=[], height=450, label="Conversation")

    # ── Shared helpers ────────────────────────────────────────────────────────

    def chat_fn(message, history, session_id, expertise):
        if not message or not message.strip():
            return history or [], "", "", "", "", ""
        try:
            resp = chatbot.generate_answer(
                message, current["char_id"], session_id,
                expertise_level=expertise if expertise != "auto" else None
            )
        except Exception as e:
            resp = {"answer": f"Error: {str(e)[:120]}", "error": True,
                    "character": "System", "title": "Error"}
        if resp.get("error"):
            bot = f"ERROR: {resp['answer']}"
            return _make_history(history, message, bot), "", "", "", "", ""

        char_name = resp.get("character", "")
        title     = resp.get("title", "")
        bot = f"**{char_name}** ({title})\n\n{resp['answer']}"
        if resp.get("confidence"):
            bot += (f"\n\n_Confidence: {resp['confidence']:.0%}"
                    f" | Topic: {resp.get('topic','?')}"
                    f" | Intent: {resp.get('intent','?')}_")
        if resp.get("anomaly"):
            bot = ("\u26a0\ufe0f **HISTORICAL CLARIFICATION**\n\n"
                   + resp["anomaly"]["correction"] + "\n\n---\n\n" + bot)

        fl = resp.get("folklore") or {}
        folklore_out = ""
        if fl and fl.get("enriched"):
            folklore_out = (f"### {fl['legend_title']}\n\n"
                            f"**Legend:** {fl['legend']}\n\n"
                            f"**Historical Fact:** {fl['historical_fact']}")

        chain_out = resp.get("causal_chain") or ""

        pred = resp.get("predicted_topics") or []
        sites = resp.get("vr_sites") or []
        enrich_lines = []
        if pred:
            enrich_lines.append("**You might ask next:**")
            for p in pred:
                sq = p.get("suggested_questions", [])
                hint = sq[0] if sq else ""
                enrich_lines.append(
                    f"- **{p['predicted_topic']}** ({p['confidence']:.0%}) — _{hint}_"
                )
        if sites:
            enrich_lines.append("\n**Explore in VR:**")
            for s in sites:
                enrich_lines.append(f"- \U0001f3db **{s['name']}** — {s['description']}")
                enrich_lines.append(f"  _{s['vr_experience']}_")
        enrich_out = "\n".join(enrich_lines)

        crit_out = ""
        if resp.get("critical_question"):
            crit_out = f"\U0001f4ad **Think Deeper:**\n\n{resp['critical_question']}"

        return _make_history(history, message, bot), "", folklore_out, chain_out, enrich_out, crit_out

    def set_character(char_id):
        current["char_id"] = char_id
        c = CHARACTERS[char_id]
        return f"**{c['name']}** — {c['title']}"

    def submit_feedback(session_id, query, rating):
        if not query:
            return "Please enter the question you rated."
        r = chatbot.provide_feedback(session_id, current["char_id"], query, float(rating))
        return f"Recorded! Reward: {r['reward']:.2f}  Epsilon: {r['epsilon']:.3f}"

    def run_finetune():
        try:
            chatbot.fine_tune()
            return (f"Fine-tuning complete!\n"
                    f"Adapter saved to: {CONFIG['local_adapter_path']}\n"
                    f"Now go to Step 2 to upload to HuggingFace.")
        except Exception as e:
            return f"Fine-tuning error: {e}"

    def do_upload(token):
        if not token or not token.strip():
            return "Please enter your Hugging Face WRITE token."
        ok = chatbot.upload_to_hf(token.strip())
        if ok:
            return (f"Uploaded to https://huggingface.co/{CONFIG['adapter_repo']}\n"
                    f"PUBLIC repo — no token needed to download.")
        return "Upload failed. Check token and internet connection."

    def gen_quiz(char_id, quiz_type, difficulty, session_id):
        try:
            q = chatbot.quiz_engine.generate_quiz(char_id, quiz_type, difficulty, session_id)
            xp = q.get("xp_reward") or q.get("xp") or 0
            lines = [f"### Quiz — {quiz_type.replace('_',' ').title()}",
                     f"**Character:** {char_id}  |  **Difficulty:** {difficulty}  |  **XP Reward:** {xp}", ""]
            if quiz_type == "multiple_choice":
                lines.append(f"**Q:** {q.get('question','')}")
                for opt in q.get("options", []):
                    lines.append(f"  {opt}")
                lines.append(f"\n Answer: {q.get('answer','')} — {q.get('explanation','')}")
            elif quiz_type == "true_false":
                lines.append(f"**Q:** {q.get('question','')}")
                lines.append(f"\n Answer: {'True' if q.get('answer') else 'False'} — {q.get('explanation','')}")
            elif quiz_type == "fill_blank":
                lines.append(f"**Q:** {q.get('question','')}")
                lines.append(f"Hint: {q.get('hint','')}")
                lines.append(f"\n Answer: {q.get('answer','')}")
            elif quiz_type == "vr_challenge":
                lines.append(f"### {q.get('title','VR Challenge')}")
                lines.append(q.get("description",""))
                lines.append("\n**Choices:**")
                for ch in q.get("choices", []):
                    icon = "Correct" if ch.get("correct") else "Wrong"
                    lines.append(f"  [{icon}] {ch['text']} — {ch['feedback']}")
            return "\n".join(lines)
        except Exception as e:
            return f"Error: {e}"

    def get_leaderboard():
        try:
            lb = chatbot.quiz_engine.get_leaderboard()
            if not lb:
                return "No quiz scores yet. Play some quizzes first!"
            lines = ["| Rank | Session | XP | Accuracy | Answered |",
                     "|------|---------|----|---------:|:--------:|"]
            for i, entry in enumerate(lb[:10], 1):
                lines.append(f"| {i} | {entry['session_id']} | {entry['xp']} | {entry['accuracy']}% | {entry['total_answered']} |")
            return "\n".join(lines)
        except Exception as e:
            return f"Error: {e}"

    def predict_fn(session_id, topic, char_id):
        try:
            mem = chatbot.temporal_memory.get_user_memory(session_id)
            hist = [h.get("topic","") for h in mem.get("narrative_thread",[])[-5:]]
            preds = chatbot.predictor.predict_next_topics(session_id, topic, char_id, hist, top_n=5)
            if not preds:
                return "No predictions yet — ask some questions first."
            lines = ["### Predicted Next Topics"]
            for p in preds:
                lines.append(f"**{p['predicted_topic']}** (confidence: {p['confidence']:.0%})")
                for sq in p.get("suggested_questions", []):
                    lines.append(f"  - _{sq}_")
            return "\n".join(lines)
        except Exception as e:
            return f"Error: {e}"

    def set_expertise(session_id, level):
        ok = chatbot.expertise_adapter.set_user_level(session_id, level)
        if not ok:
            return f"Invalid level. Choose: {list(chatbot.expertise_adapter.PROFILES.keys())}"
        profile = chatbot.expertise_adapter.PROFILES[level]
        return (f"Set to **{level}** ({profile['description']})\n"
                f"Detail level: {profile['detail_level']}\n"
                f"Go back to Chat — answers will now adapt to this level.")

    def check_sensitivity(query):
        if not query.strip():
            return "Enter a query to check."
        result = chatbot.sensitivity.analyze(query)
        if not result["is_sensitive"]:
            return "No cultural sensitivity flags detected."
        lines = ["**Sensitivity Flags Detected:**"]
        for d in result["detected_sensitivities"]:
            lines.append(f"\n**Type:** {d['sensitivity_type']}")
            lines.append(f"**Tone:** {d['tone']}")
            lines.append(f"**Guidance:** {d['guidance']}")
        return "\n".join(lines)

    def find_folklore(query):
        if not query.strip():
            return "Enter a topic to search for legends."
        legend = chatbot.folklore.find_relevant_legend(query)
        if not legend:
            return "No matching legend found.\nTry: tooth relic, perahera elephant, Galle Fort ghost, Dutugamunu"
        return (f"### {legend['title']}\n\n"
                f"**Legend:**\n{legend['legend']}\n\n"
                f"**Historical Fact:**\n{legend['historical_fact']}")

    def show_all_legends():
        lines = []
        for key, leg in chatbot.folklore.LEGENDS.items():
            lines.append(f"### {leg['title']}")
            lines.append(leg['legend'][:200] + "...")
            lines.append(f"Keywords: {', '.join(leg['keywords'][:3])}")
            lines.append("---")
        return "\n".join(lines)

    def get_causal_chain(query):
        if not query.strip():
            return "Enter a historical question. Try: Why did Kandy remain independent?"
        chain = chatbot.causal_chain.find_chain(query)
        if not chain:
            return ("No causal chain found for this query.\n"
                    "Available: Kandyan independence, Dutch cinnamon trade, Tooth Relic power\n"
                    "Try asking 'Why did Kandy remain independent?' or 'How did cinnamon trade develop?'")
        return chatbot.causal_chain.format_chain(chain)

    def discover_vr(session_id, topic, char_id):
        suggestions = chatbot.vr_discovery.suggest_sites(session_id, topic, char_id, top_n=6)
        if not suggestions:
            return "No new VR sites to suggest — you may have visited them all!"
        lines = ["### Suggested VR Experiences"]
        for s in suggestions:
            lines.append(f"\n**{s['name']}** ({s['type'].replace('_',' ')})")
            lines.append(s['description'])
            lines.append(f"VR Experience: {s['vr_experience']}")
            lines.append(f"Discovery tip: {s['discovery_trigger']}")
        return "\n".join(lines)

    def mark_vr_visited(session_id, site_id):
        if not site_id.strip():
            sites = list(chatbot.vr_discovery.VR_SITES.keys())
            return f"Enter a site_id. Available: {', '.join(sites)}"
        chatbot.vr_discovery.mark_visited(session_id, site_id.strip())
        return f"Marked '{site_id.strip()}' as visited for session {session_id}"

    def check_anomaly(query):
        if not query.strip():
            return "Enter a statement to fact-check."
        result = chatbot.anomaly_engine.detect_misconception(query)
        if not result:
            return "No historical misconceptions detected."
        return (f"MISCONCEPTION DETECTED (severity: {result['severity']})"
                f"\n\n{result['correction']}")

    def show_memory(session_id):
        mem = chatbot.temporal_memory.get_full_history(session_id)
        if not mem:
            return "No memory yet for this session."
        lines = [f"### Session: {session_id}",
                 f"- Created: {mem.get('created','?')}",
                 f"- Characters interacted: {', '.join(mem.get('character_interactions',{}).keys()) or 'none'}",
                 f"- Topics explored: {', '.join(mem.get('known_facts',{}).keys()) or 'none'}",
                 f"- Last topic: {mem.get('last_topic','none')}",
                 "", "**Recent narrative thread:**"]
        for entry in mem.get("narrative_thread",[])[-8:]:
            lines.append(f"  [{entry.get('character','?')}] {entry.get('topic','?')}")
        return "\n".join(lines)

    def get_critical_q(session_id, char_id, topic):
        q = chatbot.critical_prompter.get_challenge_question(session_id, char_id, topic or "general")
        return f"**Critical Thinking Challenge:**\n\n{q}"

    # ── UI Layout ──────────────────────────────────────────────────────────────

    with gr.Blocks(title="Sri Lanka VR Historical Chatbot") as demo:

        gr.Markdown("""
        # Sri Lanka VR Historical Chatbot
        RAG + RL + LoRA + VR Quiz + Predictive AI + Cultural Sensitivity + Folklore + Causal Chains

        Model: `TinyLlama/TinyLlama-1.1B-Chat-v1.0` — 4 Characters — No HF token required to run
        """)

        # ── Tab 1: Chat ───────────────────────────────────────────────────────
        with gr.Tab("Chat"):
            with gr.Row():
                with gr.Column(scale=3):
                    chatbot_ui = _make_chatbot()
                    with gr.Row():
                        msg = gr.Textbox(placeholder="Ask a historical question...",
                                         label="Your Question", scale=4, lines=2)
