                "question": "What cultural practices are unique to Sri Lanka?",
                "context": "Culture",
                "answer": "Sri Lanka has amazing cultural practices! Traditional Kandyan dance, ancient "
                          "Ayurvedic medicine, Buddhist rituals, Perahera festivals, traditional crafts "
                          "like mask-making and brasswork, and our unique rice and curry cuisine.",
                "character": "citizen"
            },
        ]
        print(f"Using {len(self.data)} built-in entries")
        return self.data

    def prepare_for_training(self) -> List[str]:
        """TinyLlama ChatML format for training"""
        return [
            f"<|system|>\nYou are a helpful historical guide about Sri Lanka.</s>\n"
            f"<|user|>\n{item['question']}</s>\n"
            f"<|assistant|>\n{item['answer']}</s>"
            for item in self.data
        ]

# =============================================================================
# HF UPLOADER  (public repo - no token needed to download)
# =============================================================================

class HFUploader:
    """
    Uploads the local LoRA adapter to a PUBLIC Hugging Face repository.

    Upload requires a WRITE token (one-time, your credentials only).
    Once uploaded to a PUBLIC repo, ANYONE can download without any token.
    Get write token: https://huggingface.co/settings/tokens
    """

    def __init__(self, repo_id: str, local_adapter_path: str):
        self.repo_id = repo_id
        self.local_path = Path(local_adapter_path)
        self.api = HfApi() if HF_HUB_AVAILABLE else None

    def upload(self, hf_write_token: str) -> bool:
        if not HF_HUB_AVAILABLE:
            print("huggingface_hub not installed. Run: pip install huggingface_hub")
            return False
        if not self.local_path.exists() or not any(self.local_path.iterdir()):
            print(f"No local adapter at {self.local_path}. Run fine-tuning first.")
            return False
        try:
            print(f"\nCreating public repo: {self.repo_id}")
            create_repo(
                repo_id=self.repo_id,
                token=hf_write_token,
                private=False,   # PUBLIC - no token needed to download
                exist_ok=True
            )
            print("Repo ready (public)")
            print(f"Uploading from {self.local_path} ...")
            self.api.upload_folder(
                folder_path=str(self.local_path),
                repo_id=self.repo_id,
                token=hf_write_token,
                commit_message="Upload LoRA adapter - Sri Lanka Historical Chatbot"
            )
            print(f"Adapter uploaded to https://huggingface.co/{self.repo_id}")
            print(f"Anyone can load it: PeftModel.from_pretrained(model, '{self.repo_id}')")
            print("No token required for downloading.")
            return True
        except Exception as e:
            print(f"Upload failed: {e}")
            return False

    @staticmethod
    def load_public_adapter(base_model, repo_id: str):
        """Load from PUBLIC HF repo - no token parameter needed."""
        try:
            print(f"Loading public adapter from: {repo_id}")
            model = PeftModel.from_pretrained(base_model, repo_id)
            print(f"Public adapter loaded from {repo_id}")
            return model
        except Exception as e:
            print(f"Could not load adapter from {repo_id}: {str(e)[:100]}")
            print("Using base model only. Fine-tune and upload to enable the adapter.")
            return base_model

# =============================================================================
# VECTOR DATABASE
# =============================================================================

class VectorDatabase:
    def __init__(self, embedding_model: str, max_retries: int = 3):
        self.encoder = None
        self.use_simple_search = False
        self.documents = []
        self.metadata_list = []

        print(f"Loading embedding model: {embedding_model}")
        for attempt in range(max_retries):
            try:
                if SENTENCE_TRANSFORMERS_AVAILABLE:
                    self.encoder = SentenceTransformer(
                        embedding_model, cache_folder="./model_cache"
                    )
                    print("Embedding model loaded")
                    break
            except Exception as e:
                print(f"Attempt {attempt+1}/{max_retries}: {str(e)[:80]}")
                if attempt < max_retries - 1:
                    time.sleep((attempt + 1) * 10)
                else:
                    self.use_simple_search = True
                    print("Falling back to keyword search")

        self.client = chromadb.Client(Settings(anonymized_telemetry=False))
        try:
            self.client.delete_collection("knowledge_base")
        except Exception:
            pass
        self.collection = self.client.create_collection(
            name="knowledge_base", metadata={"hnsw:space": "cosine"}
        )
        print("Vector database initialized")

    def add_documents(self, texts: List[str], metadata: List[Dict]):
        self.documents = texts
        self.metadata_list = metadata
        if not self.use_simple_search and self.encoder:
            try:
                embeddings = self.encoder.encode(texts, show_progress_bar=False)
                self.collection.add(
                    ids=[f"doc_{i}" for i in range(len(texts))],
                    embeddings=embeddings.tolist(),
                    documents=texts, metadatas=metadata
                )
                print(f"{len(texts)} documents added with embeddings")
                return
            except Exception as e:
                print(f"Embedding error: {e} - switching to keyword search")
                self.use_simple_search = True
        print(f"{len(texts)} documents stored for keyword search")

    def _keyword_retrieve(self, query: str, character_id: str,
                          top_k: int) -> Tuple[List[Dict], float]:
        t0 = time.time()
        q_words = set(query.lower().split())
        scored = []
        for doc, meta in zip(self.documents, self.metadata_list):
            if meta.get("character") not in [character_id, "all"]:
                continue
            overlap = len(q_words & set(doc.lower().split()))
            if query.lower() in doc.lower():
                overlap += 5
            if overlap > 0:
                scored.append({"text": doc, "metadata": meta,
                                "similarity": min(overlap / 10.0, 0.95)})
        scored.sort(key=lambda x: x["similarity"], reverse=True)
        return scored[:top_k], time.time() - t0

    def retrieve(self, query: str, character_id: str,
                 top_k: int = 5) -> Tuple[List[Dict], float]:
        if self.use_simple_search or not self.encoder:
            return self._keyword_retrieve(query, character_id, top_k)
        t0 = time.time()
        try:
            qe = self.encoder.encode([query])[0]
            results = self.collection.query(
                query_embeddings=[qe.tolist()], n_results=top_k * 2,
                include=["documents", "metadatas", "distances"]
            )
            retrieved = []
            for doc, meta, dist in zip(
                results["documents"][0],
                results["metadatas"][0],
                results["distances"][0]
            ):
                if meta.get("character") in [character_id, "all"]:
                    retrieved.append({"text": doc, "metadata": meta,
                                      "similarity": 1 - dist})
                    if len(retrieved) >= top_k:
                        break
            return retrieved, time.time() - t0
        except Exception as e:
            print(f"Retrieval error: {e}")
            return self._keyword_retrieve(query, character_id, top_k)

# =============================================================================
# REINFORCEMENT LEARNING
# =============================================================================

class RLRecommender:
    def __init__(self, config: Dict):
        self.lr = config["rl_learning_rate"]
        self.gamma = config["rl_gamma"]
        self.epsilon = config["exploration_rate"]
        self.epsilon_min = config["min_exploration"]
        self.epsilon_decay = config["exploration_decay"]
        self.q_table = defaultdict(lambda: defaultdict(float))
        self.user_history = defaultdict(list)
        self.character_rewards = defaultdict(lambda: defaultdict(list))
        print("RL Recommender initialized")

    def get_state(self, user_id, character, topic, history):
        recent = "_".join(history[-3:]) if history else "start"
        return f"{user_id}_{character}_{topic}_{recent}"

    def update_q_value(self, state, action, reward, next_state, next_actions):
        curr = self.q_table[state][action]
        max_next = max([self.q_table[next_state][a] for a in next_actions], default=0)
        self.q_table[state][action] = curr + self.lr * (
            reward + self.gamma * max_next - curr
        )
        self.epsilon = max(self.epsilon_min, self.epsilon * self.epsilon_decay)

    def record_feedback(self, user_id, character, topic, rating):
        self.character_rewards[character][topic].append(rating)
        self.user_history[user_id].append(f"{character}:{topic}")

    def recommend_topics(self, user_id, character, current_topic,
                         available_topics, top_n=3):
        if not available_topics:
            return []
        history = self.user_history.get(user_id, [])
        state = self.get_state(user_id, character, current_topic, history)
        scored = []
        for topic in available_topics:
            q = self.q_table[state][topic]
            avg_r = (np.mean(self.character_rewards[character][topic])
                     if self.character_rewards[character][topic] else 0)
            scored.append((topic, 0.7 * q + 0.3 * avg_r))
        scored.sort(key=lambda x: x[1], reverse=True)
        return [t for t, _ in scored[:top_n]]

    def get_q_table_stats(self):
        all_q = [v for sa in self.q_table.values() for v in sa.values()]
        return {
            "num_states":  len(self.q_table),
            "num_actions": sum(len(a) for a in self.q_table.values()),
            "avg_q_value": float(np.mean(all_q)) if all_q else 0,
            "max_q_value": float(max(all_q)) if all_q else 0,
            "min_q_value": float(min(all_q)) if all_q else 0,
        }

# =============================================================================
# USER PROFILE MANAGER
# =============================================================================

class UserProfileManager:
    def __init__(self, profile_file: str):
        self.profile_file = profile_file
        self.profiles = self._load()
        print("User Profile Manager initialized")

    def _load(self):
        if Path(self.profile_file).exists():
            try:
                with open(self.profile_file) as f:
                    return json.load(f)
            except Exception:
                pass
        return {}

    def _save(self):
        with open(self.profile_file, 'w') as f:
            json.dump(self.profiles, f, indent=2)

    def get_profile(self, user_id: str) -> Dict:
        if user_id not in self.profiles:
            self.profiles[user_id] = {
                "created": datetime.now().isoformat(),
                "queries": [], "character_usage": {},
                "topics": {}, "avg_rating": 0, "total_interactions": 0
            }
        return self.profiles[user_id]

    def update_profile(self, user_id, character, query, topic, rating=None):
        p = self.get_profile(user_id)
        p["queries"].append({"character": character, "query": query,
                              "topic": topic, "timestamp": datetime.now().isoformat()})
        p["character_usage"][character] = p["character_usage"].get(character, 0) + 1
        p["topics"][topic] = p["topics"].get(topic, 0) + 1
        p["total_interactions"] += 1
        if rating is not None:
            t = p["total_interactions"]
            p["avg_rating"] = (p["avg_rating"] * (t - 1) + rating) / t
        if len(p["queries"]) > 50:
            p["queries"] = p["queries"][-50:]
        self._save()

# =============================================================================
# INTENT CLASSIFIER
# =============================================================================

class IntentClassifier:
    INTENTS = {
        "greeting":    ["hello", "hi", "hey", "greetings", "ayubowan"],
        "identity":    ["who are you", "tell me about yourself", "introduce yourself"],
        "person":      ["who was", "who is", "tell me about", "biography"],
        "place":       ["where", "location", "which place"],
        "time":        ["when", "what year", "period", "era"],
        "description": ["what is", "what are", "describe", "explain"],
        "reason":      ["why", "reason", "what caused"],
        "process":     ["how", "process", "steps"],
        "comparison":  ["compare", "difference", "versus"],
        "list":        ["list", "name some", "what are some"]
    }
    TOPICS = {
        "king":     ["king", "vijaya", "rajasinha", "monarch", "ruler", "reign"],
        "temple":   ["temple", "dalada", "maligawa", "tooth relic", "shrine"],
        "festival": ["perahera", "festival", "ceremony", "celebration"],
        "kingdom":  ["kingdom", "kandy", "dynasty"],
        "buddhism": ["buddhist", "buddhism", "religion", "sangha"],
        "fort":     ["fort", "galle", "bastion", "rampart"],
        "trade":    ["trade", "cinnamon", "voc", "commerce"],
        "colonial": ["dutch", "portuguese", "british", "colonial"]
    }

    def classify(self, query: str) -> str:
        q = query.lower()
        for intent, kws in self.INTENTS.items():
            if any(k in q for k in kws):
                return intent
        return "general"

    def extract_topic(self, query: str) -> str:
        q = query.lower()
        for topic, kws in self.TOPICS.items():
            if any(k in q for k in kws):
                return topic
        return "general"


